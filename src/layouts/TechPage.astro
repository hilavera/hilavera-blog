---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface PageStat {
	label: string;
	value: string | number;
}

interface Props {
	title: string;
	description: string;
	eyebrow: string;
	heading: string;
	summary: string;
	stats?: PageStat[];
}

const { title, description, eyebrow, heading, summary, stats = [] } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			body {
				background:
					radial-gradient(circle at 8% -4%, rgba(56, 189, 248, 16%), transparent 28rem),
					radial-gradient(circle at 92% 6%, rgba(214, 181, 109, 13%), transparent 30rem),
					linear-gradient(180deg, var(--premium-ink) 0%, var(--premium-bg) 48%, var(--premium-bg-soft) 100%);
				color: var(--premium-soft);
			}
			.tech-page {
				isolation: isolate;
				margin: auto;
				max-width: calc(100% - 2rem);
				padding: 1.5rem 0 3.2rem;
				position: relative;
				width: min(1040px, calc(100% - 2rem));
			}
			.tech-page::before,
			.tech-page::after {
				content: '';
				inset: -1.5rem;
				pointer-events: none;
				position: absolute;
				z-index: 0;
			}
			.tech-page::before {
				background:
					linear-gradient(rgba(148, 163, 184, 5%) 1px, transparent 1px),
					linear-gradient(90deg, rgba(148, 163, 184, 5%) 1px, transparent 1px);
				background-size: 44px 44px;
				opacity: 0.24;
			}
			.tech-page::after {
				background:
					linear-gradient(120deg, transparent 14%, rgba(214, 181, 109, 10%) 48%, transparent 76%),
					radial-gradient(ellipse at 50% 0%, rgba(56, 189, 248, 10%), transparent 62%);
				opacity: 0.5;
			}
			.tech-page > * {
				position: relative;
				z-index: 1;
			}
			.page-hero,
			.surface-card {
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 7%), transparent 34%),
					linear-gradient(180deg, var(--premium-panel-strong), rgba(10, 16, 30, 78%));
				border: 1px solid var(--premium-border);
				border-radius: var(--premium-radius);
				box-shadow: var(--premium-shadow), var(--premium-inset);
			}
			.page-hero {
				background:
					linear-gradient(135deg, rgba(15, 23, 42, 96%) 0%, rgba(17, 24, 39, 90%) 56%, rgba(68, 56, 28, 70%) 100%),
					radial-gradient(circle at 16% 10%, rgba(56, 189, 248, 20%), transparent 18rem),
					linear-gradient(90deg, rgba(214, 181, 109, 18%), rgba(56, 189, 248, 10%));
				margin-bottom: 1rem;
				overflow: hidden;
				padding: 1.45rem 1.6rem;
				position: relative;
			}
			.page-hero::after {
				background: linear-gradient(90deg, transparent, rgba(214, 181, 109, 72%), rgba(139, 211, 255, 48%), transparent);
				content: '';
				height: 1px;
				left: 1rem;
				position: absolute;
				right: 1rem;
				top: 0;
			}
			.page-kicker,
			.stat-label,
			.card-kicker {
				color: var(--premium-gold-soft);
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.74rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.page-hero h1 {
				color: var(--premium-text);
				font-size: 2.6rem;
				line-height: 1.08;
				margin: 0.32rem 0;
			}
			.page-hero p {
				color: var(--premium-soft);
				line-height: 1.65;
				margin: 0;
				max-width: 720px;
			}
			.page-stats {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				list-style: none;
				margin: 1rem 0 0;
				padding: 0;
			}
			.page-stats li {
				background: rgba(var(--premium-ink-rgb), 42%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				min-width: 116px;
				padding: 0.48rem 0.65rem;
			}
			.stat-value {
				color: var(--premium-text);
				display: block;
				font-weight: 700;
				margin-top: 0.1rem;
			}
			.page-section {
				margin-top: 1rem;
			}
			.density-grid {
				display: grid;
				gap: 0.78rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
			.density-grid.two {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			.surface-card {
				padding: 0.9rem;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					transform 160ms ease;
			}
			.surface-card:hover {
				border-color: var(--premium-border-strong);
				box-shadow:
					0 16px 42px rgba(214, 181, 109, 10%),
					var(--premium-glow),
					var(--premium-inset);
				transform: translateY(-1px);
			}
			.surface-card h2,
			.surface-card h3,
			.surface-card h4 {
				color: var(--premium-text);
				font-size: 1.08rem;
				line-height: 1.3;
				margin: 0 0 0.45rem;
			}
			.surface-card p,
			.surface-card li {
				color: var(--premium-soft);
				font-size: 0.92rem;
				line-height: 1.58;
				margin: 0;
			}
			.surface-card ul,
			.surface-card ol {
				display: grid;
				gap: 0.45rem;
				margin: 0;
				padding-left: 1.1rem;
			}
			.section-heading {
				align-items: end;
				border-bottom: 1px solid var(--premium-border);
				display: flex;
				gap: 1rem;
				justify-content: space-between;
				margin-bottom: 0.8rem;
				padding-bottom: 0.6rem;
			}
			.section-heading h2 {
				color: var(--premium-text);
				font-size: 1.35rem;
				margin: 0;
			}
			.section-heading p {
				color: var(--premium-muted);
				margin: 0;
			}
			.tag-row,
			.term-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.tech-tag,
			.term-pill {
				background: rgba(56, 189, 248, 10%);
				border: 1px solid var(--premium-border);
				border-radius: 999px;
				color: var(--premium-accent-soft);
				display: inline-flex;
				font-size: 0.86rem;
				gap: 0.35rem;
				padding: 0.24rem 0.68rem;
			}
			.term-pill strong {
				color: var(--premium-text);
			}
			.page-link {
				color: var(--premium-accent);
				font-weight: 700;
				text-decoration: none;
			}
			.page-link:hover {
				color: var(--premium-gold-soft);
			}
			@media (max-width: 820px) {
				.tech-page {
					padding-top: 1rem;
				}
				.page-hero {
					padding: 1.05rem;
				}
				.page-hero h1 {
					font-size: 2.05rem;
				}
				.density-grid,
				.density-grid.two {
					grid-template-columns: 1fr;
				}
				.section-heading {
					display: block;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="tech-page premium-shell ambient-mesh">
			<section class="page-hero executive-glass luxe-border" aria-labelledby="page-title">
				<span class="page-kicker">{eyebrow}</span>
				<h1 id="page-title">{heading}</h1>
				<p>{summary}</p>
				{
					stats.length > 0 && (
						<ul class="page-stats" aria-label="页面统计">
							{stats.map((stat) => (
								<li>
									<span class="stat-label">{stat.label}</span>
									<strong class="stat-value">{stat.value}</strong>
								</li>
							))}
						</ul>
					)
				}
			</section>
			<slot />
		</main>
		<Footer />
	</body>
</html>
