---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';

interface PageStat {
	label: string;
	value: string | number;
}

interface Props {
	title: string;
	description: string;
	eyebrow: string;
	heading: string;
	summary: string;
	stats?: PageStat[];
}

const { title, description, eyebrow, heading, summary, stats = [] } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={title} description={description} />
		<style is:global>
			body {
				background:
					radial-gradient(circle at 10% 0%, rgba(34, 211, 238, 18%), transparent 26rem),
					radial-gradient(circle at 90% 12%, rgba(20, 184, 166, 16%), transparent 28rem),
					linear-gradient(180deg, #07111f 0%, #0b1220 48%, #111827 100%);
				color: #d8e8f8;
			}
			.tech-page {
				isolation: isolate;
				margin: auto;
				max-width: calc(100% - 2rem);
				padding: 1.5rem 0 3.2rem;
				position: relative;
				width: min(1040px, calc(100% - 2rem));
			}
			.tech-page::before,
			.tech-page::after {
				content: '';
				inset: -1.5rem;
				pointer-events: none;
				position: absolute;
				z-index: 0;
			}
			.tech-page::before {
				background:
					linear-gradient(rgba(125, 211, 252, 7%) 1px, transparent 1px),
					linear-gradient(90deg, rgba(125, 211, 252, 7%) 1px, transparent 1px);
				background-size: 38px 38px;
				opacity: 0.28;
			}
			.tech-page::after {
				background: linear-gradient(120deg, transparent 15%, rgba(34, 211, 238, 10%) 50%, transparent 82%);
				opacity: 0.4;
			}
			.tech-page > * {
				position: relative;
				z-index: 1;
			}
			.page-hero,
			.surface-card {
				background: rgba(15, 23, 42, 88%);
				border: 1px solid rgba(125, 211, 252, 18%);
				border-radius: 8px;
				box-shadow: 0 16px 50px rgba(2, 6, 23, 32%);
				backdrop-filter: blur(14px);
			}
			.page-hero {
				background:
					linear-gradient(135deg, rgba(15, 23, 42, 96%) 0%, rgba(12, 74, 110, 78%) 58%, rgba(6, 78, 59, 68%) 100%),
					linear-gradient(90deg, rgba(34, 211, 238, 24%), rgba(20, 184, 166, 12%));
				margin-bottom: 1rem;
				overflow: hidden;
				padding: 1.45rem 1.6rem;
			}
			.page-kicker,
			.stat-label,
			.card-kicker {
				color: #67e8f9;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.74rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				text-transform: uppercase;
			}
			.page-hero h1 {
				color: #f8fafc;
				font-size: 2.6rem;
				line-height: 1.08;
				margin: 0.32rem 0;
			}
			.page-hero p {
				color: #cbd5e1;
				line-height: 1.65;
				margin: 0;
				max-width: 720px;
			}
			.page-stats {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				list-style: none;
				margin: 1rem 0 0;
				padding: 0;
			}
			.page-stats li {
				background: rgba(15, 23, 42, 72%);
				border: 1px solid rgba(125, 211, 252, 22%);
				border-radius: 8px;
				min-width: 116px;
				padding: 0.48rem 0.65rem;
			}
			.stat-value {
				color: #f8fafc;
				display: block;
				font-weight: 700;
				margin-top: 0.1rem;
			}
			.page-section {
				margin-top: 1rem;
			}
			.density-grid {
				display: grid;
				gap: 0.78rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
			}
			.density-grid.two {
				grid-template-columns: repeat(2, minmax(0, 1fr));
			}
			.surface-card {
				padding: 0.9rem;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					transform 160ms ease;
			}
			.surface-card:hover {
				border-color: rgba(34, 211, 238, 38%);
				box-shadow:
					0 10px 30px rgba(8, 145, 178, 16%),
					inset 0 1px 0 rgba(255, 255, 255, 8%);
				transform: translateY(-1px);
			}
			.surface-card h2,
			.surface-card h3,
			.surface-card h4 {
				color: #f8fafc;
				font-size: 1.08rem;
				line-height: 1.3;
				margin: 0 0 0.45rem;
			}
			.surface-card p,
			.surface-card li {
				color: #cbd5e1;
				font-size: 0.92rem;
				line-height: 1.58;
				margin: 0;
			}
			.surface-card ul,
			.surface-card ol {
				display: grid;
				gap: 0.45rem;
				margin: 0;
				padding-left: 1.1rem;
			}
			.section-heading {
				align-items: end;
				border-bottom: 1px solid rgba(125, 211, 252, 16%);
				display: flex;
				gap: 1rem;
				justify-content: space-between;
				margin-bottom: 0.8rem;
				padding-bottom: 0.6rem;
			}
			.section-heading h2 {
				color: #f8fafc;
				font-size: 1.35rem;
				margin: 0;
			}
			.section-heading p {
				color: #94a3b8;
				margin: 0;
			}
			.tag-row,
			.term-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.tech-tag,
			.term-pill {
				background: rgba(8, 47, 73, 36%);
				border: 1px solid rgba(125, 211, 252, 18%);
				border-radius: 999px;
				color: #bae6fd;
				display: inline-flex;
				font-size: 0.86rem;
				gap: 0.35rem;
				padding: 0.24rem 0.68rem;
			}
			.term-pill strong {
				color: #f8fafc;
			}
			.page-link {
				color: #67e8f9;
				font-weight: 700;
				text-decoration: none;
			}
			.page-link:hover {
				color: #a7f3d0;
			}
			@media (max-width: 820px) {
				.tech-page {
					padding-top: 1rem;
				}
				.page-hero {
					padding: 1.05rem;
				}
				.page-hero h1 {
					font-size: 2.05rem;
				}
				.density-grid,
				.density-grid.two {
					grid-template-columns: 1fr;
				}
				.section-heading {
					display: block;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="tech-page">
			<section class="page-hero" aria-labelledby="page-title">
				<span class="page-kicker">{eyebrow}</span>
				<h1 id="page-title">{heading}</h1>
				<p>{summary}</p>
				{
					stats.length > 0 && (
						<ul class="page-stats" aria-label="页面统计">
							{stats.map((stat) => (
								<li>
									<span class="stat-label">{stat.label}</span>
									<strong class="stat-value">{stat.value}</strong>
								</li>
							))}
						</ul>
					)
				}
			</section>
			<slot />
		</main>
		<Footer />
	</body>
</html>
