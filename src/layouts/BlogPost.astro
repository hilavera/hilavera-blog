---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import FormattedDate from '../components/FormattedDate.astro';
import TechPage from './TechPage.astro';
import { withBase } from '../consts';

interface ArticleNavItem {
	title: string;
	description: string;
	href: string;
	category: string;
}

interface TocItem {
	title: string;
}

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	heroImage?: ImageMetadata;
	category?: string;
	tags?: string[];
	readingTime?: number;
	toc?: TocItem[];
	newerPost?: ArticleNavItem;
	olderPost?: ArticleNavItem;
	relatedPosts?: ArticleNavItem[];
}

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category = '开发日志',
	tags = [],
	readingTime = 1,
	toc = [],
	newerPost,
	olderPost,
	relatedPosts = [],
} = Astro.props;
---

<TechPage
	title={title}
	description={description}
	eyebrow={category}
	heading={title}
	summary={description}
	stats={[
		{ label: '阅读', value: `${readingTime} 分钟` },
		{ label: '分类', value: category },
		{ label: '标签', value: `${tags.length} 个` },
	]}
>
	<article class="article-shell">
		<div class="article-main surface-card">
			{
				heroImage && (
					<div class="article-hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)
			}

			<div class="article-meta">
				<span>
					发布于
					<FormattedDate date={pubDate} />
				</span>
				{
					updatedDate && (
						<span>
							更新于
							<FormattedDate date={updatedDate} />
						</span>
					)
				}
				<a href={withBase('/blog/')}>返回文章列表</a>
			</div>

			<div class="article-tags" aria-label="文章标签">
				<a class="tech-tag" href={withBase('/categories/')}>{category}</a>
				{tags.map((tag) => <span class="tech-tag">{tag}</span>)}
			</div>

			<div class="article-prose">
				<slot />
			</div>
		</div>

		<aside class="article-aside" aria-label="文章辅助信息">
			<section class="surface-card article-panel article-toc">
				<span class="card-kicker">Outline</span>
				<h2>本篇速览</h2>
				{
					toc.length > 0 ? (
						<ol>
							{toc.map((item) => (
								<li>{item.title}</li>
							))}
						</ol>
					) : (
						<p>这篇文章是短记录，适合直接从头读到尾。</p>
					)
				}
			</section>

			<section class="surface-card article-panel">
				<span class="card-kicker">Next step</span>
				<h2>阅读建议</h2>
				<p>先看目标和问题，再看操作过程，最后对照验证方式。这样读技术记录更容易复用。</p>
			</section>

			{
				relatedPosts.length > 0 && (
					<section class="surface-card article-panel related-reading">
						<span class="card-kicker">Related</span>
						<h2>相关阅读</h2>
						<ul>
							{relatedPosts.map((post) => (
								<li>
									<a href={post.href}>{post.title}</a>
									<span>{post.category}</span>
								</li>
							))}
						</ul>
					</section>
				)
			}
		</aside>
	</article>

	<nav class="article-nav" aria-label="上一篇和下一篇">
		{
			olderPost ? (
				<a class="surface-card article-nav-card" href={olderPost.href}>
					<span class="card-kicker">上一篇</span>
					<strong>{olderPost.title}</strong>
					<small>{olderPost.description}</small>
				</a>
			) : (
				<a class="surface-card article-nav-card" href={withBase('/blog/')}>
					<span class="card-kicker">文章索引</span>
					<strong>回到开发日志索引</strong>
					<small>从分类、标签和发布时间继续浏览。</small>
				</a>
			)
		}
		{
			newerPost ? (
				<a class="surface-card article-nav-card" href={newerPost.href}>
					<span class="card-kicker">更新一篇</span>
					<strong>{newerPost.title}</strong>
					<small>{newerPost.description}</small>
				</a>
			) : (
				<a class="surface-card article-nav-card" href={withBase('/categories/')}>
					<span class="card-kicker">分类地图</span>
					<strong>按主题继续阅读</strong>
					<small>查看学习笔记、项目复盘和工具配置。</small>
				</a>
			)
		}
	</nav>

	<style is:global>
		.article-shell {
			display: grid;
			gap: 1rem;
			grid-template-columns: minmax(0, 1fr) 280px;
			margin-top: 1rem;
		}
		.article-main {
			padding: 0;
			overflow: hidden;
		}
		.article-main:hover,
		.article-panel:hover,
		.article-nav-card:hover {
			transform: none;
		}
		.article-hero-image {
			border-bottom: 1px solid rgba(125, 211, 252, 18%);
			max-height: 340px;
			overflow: hidden;
		}
		.article-hero-image img {
			display: block;
			height: 100%;
			object-fit: cover;
			width: 100%;
		}
		.article-meta,
		.article-tags {
			display: flex;
			flex-wrap: wrap;
			gap: 0.5rem;
			padding: 0 1.05rem;
		}
		.article-meta {
			border-bottom: 1px solid rgba(125, 211, 252, 12%);
			color: #94a3b8;
			font-size: 0.88rem;
			justify-content: space-between;
			padding-bottom: 0.72rem;
			padding-top: 0.9rem;
		}
		.article-meta a {
			color: #67e8f9;
			font-weight: 700;
			text-decoration: none;
		}
		.article-meta a:hover,
		.related-reading a:hover,
		.article-nav-card:hover strong {
			color: #a7f3d0;
		}
		.article-tags {
			padding-top: 0.9rem;
		}
		.article-tags a {
			text-decoration: none;
		}
		.article-prose {
			color: #dbeafe;
			font-size: 1rem;
			line-height: 1.78;
			padding: 0.2rem 1.05rem 1.25rem;
		}
		.article-prose :where(h2, h3) {
			color: #f8fafc;
			line-height: 1.28;
			margin: 1.45rem 0 0.5rem;
		}
		.article-prose h2 {
			border-top: 1px solid rgba(125, 211, 252, 14%);
			font-size: 1.35rem;
			padding-top: 1rem;
		}
		.article-prose h3 {
			color: #bae6fd;
			font-size: 1.08rem;
		}
		.article-prose :where(p, li) {
			color: #cbd5e1;
		}
		.article-prose a {
			color: #67e8f9;
			font-weight: 700;
		}
		.article-prose :where(ul, ol) {
			padding-left: 1.35rem;
		}
		.article-prose blockquote {
			background: rgba(8, 47, 73, 28%);
			border-left: 3px solid #22d3ee;
			border-radius: 8px;
			margin: 1rem 0;
			padding: 0.7rem 0.9rem;
		}
		.article-prose pre {
			background: rgba(2, 6, 23, 82%);
			border: 1px solid rgba(125, 211, 252, 16%);
			border-radius: 8px;
			overflow-x: auto;
			padding: 0.85rem;
		}
		.article-prose code {
			background: rgba(8, 47, 73, 45%);
			border: 1px solid rgba(125, 211, 252, 14%);
			border-radius: 6px;
			color: #bae6fd;
			font-size: 0.9em;
			padding: 0.1rem 0.3rem;
		}
		.article-prose pre code {
			background: transparent;
			border: 0;
			color: #dbeafe;
			padding: 0;
		}
		.article-aside {
			display: grid;
			gap: 0.8rem;
			align-content: start;
			position: sticky;
			top: 1rem;
		}
		.article-panel {
			padding: 0.85rem;
		}
		.article-panel h2 {
			font-size: 1rem;
		}
		.article-panel ol,
		.article-panel ul {
			display: grid;
			gap: 0.45rem;
			margin: 0.55rem 0 0;
			padding-left: 1.05rem;
		}
		.related-reading ul {
			list-style: none;
			padding-left: 0;
		}
		.related-reading li {
			display: grid;
			gap: 0.15rem;
		}
		.related-reading a {
			color: #f8fafc;
			font-weight: 700;
			text-decoration: none;
		}
		.related-reading span {
			color: #67e8f9;
			font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
			font-size: 0.75rem;
			text-transform: uppercase;
		}
		.article-nav {
			display: grid;
			gap: 0.85rem;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			margin-top: 1rem;
		}
		.article-nav-card {
			color: inherit;
			display: grid;
			gap: 0.25rem;
			text-decoration: none;
		}
		.article-nav-card strong {
			color: #f8fafc;
			font-size: 1.02rem;
			line-height: 1.35;
		}
		.article-nav-card small {
			color: #94a3b8;
			line-height: 1.55;
		}
		@media (max-width: 900px) {
			.article-shell {
				grid-template-columns: 1fr;
			}
			.article-aside {
				position: static;
			}
		}
		@media (max-width: 640px) {
			.article-nav {
				grid-template-columns: 1fr;
			}
			.article-meta {
				display: grid;
			}
		}
	</style>
</TechPage>
