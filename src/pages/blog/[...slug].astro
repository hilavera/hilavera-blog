---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { withBase } from '../../consts';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const { Content } = await render(post);

const currentIndex = posts.findIndex((entry) => entry.id === post.id);
const newerPost = currentIndex > 0 ? posts[currentIndex - 1] : undefined;
const olderPost = currentIndex >= 0 && currentIndex < posts.length - 1 ? posts[currentIndex + 1] : undefined;
const currentTags = new Set(post.data.tags);

const toNavItem = (entry: CollectionEntry<'blog'>) => ({
	title: entry.data.title,
	description: entry.data.description,
	href: withBase(`/blog/${entry.id}/`),
	category: entry.data.category,
});

const scoredRelatedPosts = posts
	.filter((entry) => entry.id !== post.id)
	.map((entry) => ({
		entry,
		score:
			(entry.data.category === post.data.category ? 4 : 0) +
			entry.data.tags.filter((tag) => currentTags.has(tag)).length,
	}))
	.sort((a, b) => b.score - a.score || b.entry.data.pubDate.valueOf() - a.entry.data.pubDate.valueOf());
const relatedPosts = (scoredRelatedPosts.some((item) => item.score > 0)
	? scoredRelatedPosts.filter((item) => item.score > 0)
	: scoredRelatedPosts
)
	.slice(0, 3)
	.map(({ entry }) => toNavItem(entry));
const bodyText = post.body ?? '';
const bodyWithoutCode = bodyText.replace(/```[\s\S]*?```/g, '');
const readingTime = Math.max(1, Math.ceil(bodyWithoutCode.replace(/\s/g, '').length / 500));
const toc = Array.from(bodyText.matchAll(/^##\s+(.+)$/gm))
	.map((match) => ({ title: match[1].trim() }))
	.slice(0, 6);
---

<BlogPost
	{...post.data}
	readingTime={readingTime}
	toc={toc}
	newerPost={newerPost && toNavItem(newerPost)}
	olderPost={olderPost && toNavItem(olderPost)}
	relatedPosts={relatedPosts}
>
	<Content />
</BlogPost>
