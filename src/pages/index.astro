---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from '../consts';

const profileName = 'hilavera';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
const categories = Array.from(new Set(posts.map((post) => post.data.category)));
const categoryCounts = categories.map((category) => ({
	category,
	count: posts.filter((post) => post.data.category === category).length,
}));
const allTags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).slice(0, 8);

const navItems = [
	{ id: 'home', label: '主页', summary: '开发者状态' },
	{ id: 'posts', label: '文章', summary: '发布记录' },
	{ id: 'categories', label: '分类', summary: '知识模块' },
	{ id: 'about', label: '关于', summary: '学习路线' },
];

const statusItems = [
	{ label: 'NOW', value: 'Astro + GitHub Pages' },
	{ label: 'LEARNING', value: 'JavaScript / CSS / Markdown' },
	{ label: 'NEXT', value: 'TypeScript 基础和组件拆分' },
];

const learningProgress = [
	{ label: 'HTML / CSS 页面结构', value: 72, note: '能搭出稳定布局，继续练响应式和细节还原。' },
	{ label: 'JavaScript 基础交互', value: 48, note: '能写切换、筛选、状态更新这类小功能。' },
	{ label: 'Astro 博客发布', value: 82, note: '已完成 GitHub Pages 发布，继续补内容和 SEO。' },
];

const currentPlans = [
	'把首页做成可搜索、可筛选的个人开发空间。',
	'每周至少写一篇开发日志，记录真实问题和解决过程。',
	'补 TypeScript 基础，下一步尝试把页面组件拆得更清楚。',
];

const projectCards = [
	{
		name: 'hilavera-blog',
		status: '已上线',
		description: '用 Astro + GitHub Pages 搭建的个人博客，当前重点是内容结构和首页体验。',
	},
	{
		name: '开发日志系统',
		status: '持续更新',
		description: '把学习路线、踩坑记录、项目复盘写成可回看的文章。',
	},
	{
		name: '前端练习清单',
		status: '准备中',
		description: '后续用小组件练习 HTML、CSS、JavaScript 和 TypeScript。',
	},
];

const techStack = ['Astro', 'HTML', 'CSS', 'JavaScript', 'Markdown', 'Git', 'GitHub Pages', 'Chrome DevTools'];

const commandItems = [
	...navItems.map((item) => ({
		kind: 'panel',
		label: item.label,
		description: item.summary,
		target: item.id,
		search: `${item.label} ${item.summary}`,
	})),
	...categoryCounts.map(({ category, count }) => ({
		kind: 'category',
		label: category,
		description: `${count} 篇文章`,
		target: category,
		search: `${category} 分类 ${count} 篇文章`,
	})),
	...posts.map((post) => ({
		kind: 'post',
		label: post.data.title,
		description: post.data.description,
		href: withBase(`/blog/${post.id}/`),
		search: `${post.data.title} ${post.data.description} ${post.data.category} ${post.data.tags.join(' ')}`,
	})),
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				background:
					radial-gradient(circle at 12% -4%, rgba(56, 189, 248, 16%), transparent 28rem),
					radial-gradient(circle at 88% 4%, rgba(214, 181, 109, 13%), transparent 30rem),
					linear-gradient(180deg, var(--premium-ink) 0%, var(--premium-bg) 48%, var(--premium-bg-soft) 100%);
				color: var(--premium-soft);
			}
			main.space-home {
				width: min(1040px, calc(100% - 2rem));
				max-width: calc(100% - 2rem);
				isolation: isolate;
				padding: 1.5rem 0 3.2rem;
			}
			.tech-shell {
				position: relative;
			}
			.visual-grid::before,
			.visual-grid::after {
				content: '';
				inset: -1.5rem;
				pointer-events: none;
				position: absolute;
				z-index: 0;
			}
			.visual-grid::before {
				background:
					repeating-linear-gradient(
						0deg,
						rgba(148, 163, 184, 5%) 0,
						rgba(148, 163, 184, 5%) 1px,
						transparent 1px,
						transparent 18px
					),
					linear-gradient(120deg, transparent 10%, rgba(214, 181, 109, 10%) 50%, transparent 88%);
				opacity: 0.24;
			}
			.visual-grid::after {
				background:
					linear-gradient(90deg, transparent, rgba(214, 181, 109, 10%), transparent),
					radial-gradient(ellipse at 50% 0%, rgba(56, 189, 248, 10%), transparent 58%);
				opacity: 0.55;
			}
			.profile-hero,
			.space-layout {
				position: relative;
				z-index: 1;
			}
			.profile-hero {
				background:
					linear-gradient(135deg, rgba(15, 23, 42, 96%) 0%, rgba(17, 24, 39, 90%) 58%, rgba(68, 56, 28, 72%) 100%),
					radial-gradient(circle at 18% 12%, rgba(56, 189, 248, 20%), transparent 18rem),
					linear-gradient(90deg, rgba(214, 181, 109, 18%), rgba(56, 189, 248, 10%));
				border: 1px solid var(--premium-border);
				border-radius: var(--premium-radius);
				box-shadow: var(--premium-shadow), var(--premium-inset);
				margin-bottom: 1rem;
				overflow: hidden;
				position: relative;
			}
			.profile-hero::before {
				background-image:
					linear-gradient(rgba(148, 163, 184, 6%) 1px, transparent 1px),
					linear-gradient(90deg, rgba(148, 163, 184, 6%) 1px, transparent 1px);
				background-size: 44px 44px;
				content: '';
				inset: 0;
				opacity: 0.34;
				position: absolute;
			}
			.profile-hero.surface-glow::after {
				background: linear-gradient(120deg, transparent 8%, rgba(214, 181, 109, 16%) 44%, rgba(255, 255, 255, 10%) 58%, transparent 72%);
				content: '';
				inset: 0;
				opacity: 0.35;
				position: absolute;
				transform: translateX(-55%);
			}
			.profile-cover {
				min-height: 210px;
				padding: 1.55rem 1.7rem;
				position: relative;
				z-index: 1;
			}
			.profile-cover::after {
				background: linear-gradient(90deg, transparent, var(--premium-gold), var(--premium-accent), transparent);
				bottom: 0;
				content: '';
				height: 3px;
				left: 0;
				position: absolute;
				right: 0;
			}
			.profile-kicker,
			.code-line {
				align-items: center;
				color: var(--premium-accent);
				display: inline-flex;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.76rem;
				font-weight: 700;
				gap: 0.45rem;
				letter-spacing: 0.06em;
				margin: 0 0 0.55rem;
				text-transform: uppercase;
			}
			.signal-dot {
				background: #22c55e;
				border-radius: 999px;
				box-shadow: 0 0 12px rgba(34, 197, 94, 62%);
				display: inline-block;
				height: 0.55rem;
				width: 0.55rem;
			}
			.profile-name {
				color: var(--premium-text);
				font-size: 2.9rem;
				letter-spacing: 0;
				line-height: 1.05;
				margin-bottom: 0.3rem;
			}
			.profile-description {
				color: var(--premium-soft);
				font-size: 0.98rem;
				line-height: 1.65;
				max-width: 640px;
				margin: 0;
			}
			.code-line {
				margin-top: 0.75rem;
			}
			.profile-stats,
			.status-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				margin: 1.05rem 0 0;
			}
			.profile-stats div,
			.status-chip {
				background: rgba(var(--premium-ink-rgb), 42%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				box-shadow: var(--premium-inset);
				padding: 0.48rem 0.65rem;
			}
			.profile-stats div {
				min-width: 96px;
			}
			.status-chip {
				flex: 1 1 178px;
				min-width: 0;
			}
			.profile-stats dt,
			.status-chip span {
				color: var(--premium-accent);
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.08em;
			}
			.profile-stats dd,
			.status-chip strong {
				color: var(--premium-text);
				display: block;
				font-size: 0.92rem;
				font-weight: 700;
				margin: 0.05rem 0 0;
			}
			.space-layout {
				align-items: start;
				display: grid;
				gap: 1rem;
				grid-template-columns: 196px minmax(0, 1fr);
			}
			.space-sidebar,
			.space-panel {
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 7%), transparent 34%),
					linear-gradient(180deg, var(--premium-panel-strong), rgba(10, 16, 30, 78%));
				border: 1px solid var(--premium-border);
				box-shadow: var(--premium-shadow), var(--premium-inset);
			}
			.space-sidebar {
				border-radius: var(--premium-radius);
				display: grid;
				gap: 0.35rem;
				padding: 0.55rem;
				position: sticky;
				top: 1em;
			}
			.space-tab {
				background: transparent;
				border: 1px solid transparent;
				border-radius: 10px;
				color: var(--premium-soft);
				cursor: pointer;
				display: grid;
				font: inherit;
				gap: 0.08rem;
				padding: 0.58rem 0.68rem;
				text-align: left;
				width: 100%;
			}
			.space-tab:hover,
			.space-tab.is-active {
				background:
					linear-gradient(90deg, rgba(214, 181, 109, 16%), transparent),
					rgba(56, 189, 248, 10%);
				border-color: var(--premium-border-strong);
				color: var(--premium-text);
			}
			.focus-ring:focus-visible {
				box-shadow: 0 0 0 3px rgba(214, 181, 109, 18%);
				outline: 1px solid rgba(214, 181, 109, 62%);
				outline-offset: 2px;
			}
			.space-tab span {
				font-weight: 700;
				line-height: 1.2;
			}
			.space-tab small {
				color: var(--premium-muted);
				font-size: 0.75rem;
				line-height: 1.3;
			}
			.space-content {
				min-width: 0;
			}
			.space-panel {
				border-radius: var(--premium-radius);
				min-height: 380px;
				overflow: hidden;
				padding: 1.15rem;
				position: relative;
			}
			.space-panel::before {
				background: linear-gradient(90deg, transparent, rgba(214, 181, 109, 70%), rgba(139, 211, 255, 44%), transparent);
				content: '';
				height: 1px;
				left: 0.9rem;
				opacity: 0.6;
				position: absolute;
				right: 0.9rem;
				top: 0;
			}
			.space-panel > * {
				position: relative;
				z-index: 1;
			}
			.soft-reveal {
				animation: panelEnter 220ms ease-out both;
			}
			.space-panel[hidden] {
				display: none;
			}
			.panel-heading {
				align-items: start;
				border-bottom: 1px solid var(--premium-border);
				display: flex;
				gap: 0.85rem;
				justify-content: space-between;
				margin-bottom: 0.95rem;
				padding-bottom: 0.68rem;
			}
			.panel-heading h2 {
				color: var(--premium-text);
				font-size: 1.48rem;
				line-height: 1.2;
			}
			.panel-heading p,
			.feature-item p,
			.post-item p,
			.about-body p {
				color: var(--premium-soft);
				margin: 0;
			}
			.panel-link,
			.post-item a,
			.category-pill {
				color: var(--premium-accent);
			}
			.panel-link {
				font-size: 0.86rem;
				font-weight: 700;
				white-space: nowrap;
			}
			.feature-grid {
				display: grid;
				gap: 0.68rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				margin-bottom: 0.95rem;
			}
			.feature-item,
			.post-item {
				background: rgba(var(--premium-ink-rgb), 32%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				padding: 0.72rem;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					background 160ms ease,
					transform 160ms ease;
			}
			.feature-item:hover,
			.post-item:hover,
			.dashboard-card:hover,
			.project-card:hover {
				border-color: var(--premium-border-strong);
				box-shadow:
					0 16px 42px rgba(214, 181, 109, 10%),
					var(--premium-glow),
					var(--premium-inset);
				transform: translateY(-1px);
			}
			.feature-item h3,
			.post-item h3 {
				color: var(--premium-text);
				font-size: 1.02rem;
				line-height: 1.3;
				margin-bottom: 0.28rem;
			}
			.post-list {
				display: grid;
				gap: 0.68rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-item a {
				text-decoration: none;
			}
			.post-item a:hover {
				color: var(--premium-gold-soft);
			}
			.post-meta {
				color: var(--premium-muted);
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.78rem;
				margin: 0 0 0.2rem;
			}
			.dashboard-grid,
			.project-grid {
				display: grid;
				gap: 0.68rem;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				margin: 0.95rem 0;
			}
			.dashboard-card,
			.project-card {
				background:
					linear-gradient(135deg, rgba(214, 181, 109, 10%), rgba(56, 189, 248, 8%)),
					rgba(var(--premium-ink-rgb), 36%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				padding: 0.82rem;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					background 160ms ease,
					transform 160ms ease;
			}
			.dashboard-card h3,
			.project-card h3,
			.interaction-card h3,
			.about-body h3 {
				color: var(--premium-text);
				font-size: 1.02rem;
				line-height: 1.3;
				margin-bottom: 0.5rem;
			}
			.progress-list,
			.plan-list,
			.project-list {
				display: grid;
				gap: 0.7rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.progress-top,
			.project-head {
				align-items: center;
				display: flex;
				gap: 0.7rem;
				justify-content: space-between;
			}
			.progress-top span,
			.project-head h4 {
				color: var(--premium-text);
				font-size: 0.92rem;
				font-weight: 700;
				margin: 0;
			}
			.progress-top strong,
			.project-status {
				color: var(--premium-accent);
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.76rem;
			}
			.progress-track {
				background: rgba(var(--premium-ink-rgb), 70%);
				border: 1px solid var(--premium-border);
				border-radius: 999px;
				height: 0.46rem;
				margin: 0.35rem 0;
				overflow: hidden;
			}
			.progress-track span {
				background: linear-gradient(90deg, var(--premium-accent-strong), var(--premium-gold));
				border-radius: inherit;
				box-shadow: 0 0 18px rgba(214, 181, 109, 26%);
				display: block;
				height: 100%;
				width: var(--progress);
			}
			.progress-note,
			.project-card p {
				color: var(--premium-soft);
				font-size: 0.88rem;
				line-height: 1.55;
				margin: 0;
			}
			.interaction-card {
				background:
					linear-gradient(135deg, rgba(214, 181, 109, 10%), rgba(56, 189, 248, 8%)),
					rgba(var(--premium-ink-rgb), 38%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				padding: 0.82rem;
			}
			.interaction-note {
				color: var(--premium-muted);
				font-size: 0.84rem;
				line-height: 1.55;
				margin-bottom: 0.75rem;
			}
			.interaction-grid {
				display: grid;
				gap: 0.68rem;
				grid-template-columns: 1fr 1fr;
			}
			.interaction-field {
				display: grid;
				gap: 0.3rem;
			}
			.interaction-field.full {
				grid-column: 1 / -1;
			}
			.interaction-field input,
			.interaction-field textarea {
				background: rgba(var(--premium-ink-rgb), 55%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				color: var(--premium-text);
				font: inherit;
				font-size: 0.92rem;
				padding: 0.48rem 0.62rem;
			}
			.interaction-field textarea {
				min-height: 5.5rem;
				resize: vertical;
			}
			.interaction-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem;
			}
			.interaction-button {
				background: rgba(var(--premium-ink-rgb), 58%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				color: var(--premium-soft);
				cursor: pointer;
				font: inherit;
				font-weight: 700;
				padding: 0.46rem 0.72rem;
			}
			.interaction-button.is-active {
				background: linear-gradient(135deg, rgba(214, 181, 109, 72%), rgba(56, 189, 248, 28%));
				border-color: rgba(214, 181, 109, 58%);
				color: var(--premium-text);
			}
			.comment-preview {
				background: rgba(var(--premium-ink-rgb), 34%);
				border: 1px dashed var(--premium-border);
				border-radius: 10px;
				color: var(--premium-soft);
				font-size: 0.88rem;
				line-height: 1.55;
				min-height: 2.4rem;
				padding: 0.62rem;
				white-space: pre-wrap;
			}
			.local-badge {
				color: var(--premium-accent);
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.72rem;
			}
			.plan-list {
				counter-reset: plan;
			}
			.plan-list li {
				color: var(--premium-soft);
				line-height: 1.55;
				padding-left: 2rem;
				position: relative;
			}
			.plan-list li::before {
				background: rgba(214, 181, 109, 16%);
				border: 1px solid rgba(214, 181, 109, 32%);
				border-radius: 999px;
				color: var(--premium-accent);
				content: counter(plan, decimal-leading-zero);
				counter-increment: plan;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.68rem;
				font-weight: 700;
				left: 0;
				line-height: 1.35rem;
				position: absolute;
				text-align: center;
				top: 0.1rem;
				width: 1.35rem;
			}
			.post-tools {
				align-items: end;
				display: grid;
				gap: 0.68rem;
				grid-template-columns: minmax(0, 1fr) 180px auto;
				margin-bottom: 0.9rem;
			}
			.filter-field {
				display: grid;
				gap: 0.3rem;
			}
			.tool-label,
			.filter-count {
				color: var(--premium-accent);
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				text-transform: uppercase;
			}
			.filter-field input,
			.filter-field select {
				background: rgba(var(--premium-ink-rgb), 55%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				color: var(--premium-text);
				font: inherit;
				font-size: 0.92rem;
				min-height: 2.25rem;
				padding: 0.45rem 0.62rem;
			}
			.filter-field input:focus,
			.filter-field select:focus {
				border-color: rgba(214, 181, 109, 72%);
				box-shadow: 0 0 0 3px rgba(214, 181, 109, 12%);
				outline: none;
			}
			.filter-count {
				margin: 0 0 0.42rem;
				white-space: nowrap;
			}
			.post-item.is-hidden {
				display: none;
			}
			.category-grid,
			.tag-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.category-pill,
			.tag-pill {
				background: rgba(56, 189, 248, 10%);
				border: 1px solid var(--premium-border);
				border-radius: 999px;
				display: inline-flex;
				gap: 0.38rem;
				padding: 0.22rem 0.68rem;
				text-decoration: none;
			}
			button.category-pill {
				color: var(--premium-accent);
				cursor: pointer;
				font: inherit;
			}
			.category-pill strong {
				color: var(--premium-text);
			}
			.category-pill span,
			.tag-pill {
				color: var(--premium-accent-soft);
				font-size: 0.85rem;
			}
			.about-body {
				display: grid;
				gap: 0.85rem;
			}
			.tech-stack {
				margin-top: 0.1rem;
			}
			.about-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}
			.button {
				background: linear-gradient(135deg, var(--premium-accent-strong), var(--premium-gold));
				border: 1px solid var(--premium-border-strong);
				border-radius: 10px;
				color: var(--premium-ink);
				display: inline-block;
				font-weight: 700;
				padding: 0.46rem 0.78rem;
				text-decoration: none;
			}
			.button.secondary {
				background: rgba(var(--premium-ink-rgb), 58%);
				color: var(--premium-accent);
			}
			.empty-state {
				color: var(--premium-muted);
			}
			.command-trigger {
				align-items: center;
				background:
					linear-gradient(135deg, rgba(214, 181, 109, 16%), rgba(56, 189, 248, 10%)),
					rgba(var(--premium-ink-rgb), 58%);
				border: 1px solid var(--premium-border-strong);
				border-radius: 10px;
				color: var(--premium-text);
				cursor: pointer;
				display: inline-flex;
				font: inherit;
				font-weight: 700;
				gap: 0.7rem;
				margin-top: 1rem;
				padding: 0.55rem 0.75rem;
				transition:
					background 160ms ease,
					border-color 160ms ease,
					transform 160ms ease;
			}
			.command-trigger:hover {
				background:
					linear-gradient(135deg, rgba(214, 181, 109, 24%), rgba(56, 189, 248, 16%)),
					rgba(var(--premium-ink-rgb), 64%);
				border-color: rgba(214, 181, 109, 62%);
				transform: translateY(-1px);
			}
			.command-trigger kbd,
			.command-close,
			.command-item em,
			.command-kicker {
				color: var(--premium-accent);
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
			}
			.command-trigger kbd {
				background: rgba(var(--premium-ink-rgb), 64%);
				border: 1px solid var(--premium-border);
				border-radius: 7px;
				font-size: 0.72rem;
				padding: 0.12rem 0.38rem;
			}
			.command-dialog {
				background: transparent;
				border: 0;
				color: var(--premium-soft);
				max-height: min(680px, calc(100vh - 2rem));
				max-width: min(680px, calc(100% - 2rem));
				padding: 0;
				width: 100%;
			}
			.command-dialog::backdrop {
				background: rgba(2, 6, 18, 76%);
			}
			.command-shell {
				background:
					linear-gradient(145deg, rgba(255, 255, 255, 7%), transparent 32%),
					var(--premium-panel-strong);
				border: 1px solid var(--premium-border-strong);
				border-radius: var(--premium-radius);
				box-shadow: var(--premium-shadow), var(--premium-inset);
				overflow: hidden;
				padding: 1rem;
			}
			.command-header {
				align-items: start;
				display: flex;
				gap: 1rem;
				justify-content: space-between;
			}
			.command-header h2 {
				color: var(--premium-text);
				font-size: 1.45rem;
				margin: 0;
			}
			.command-kicker {
				font-size: 0.68rem;
				font-weight: 700;
				letter-spacing: 0.08em;
				margin: 0 0 0.2rem;
			}
			.command-close {
				background: rgba(var(--premium-ink-rgb), 58%);
				border: 1px solid var(--premium-border);
				border-radius: 8px;
				cursor: pointer;
				font-size: 0.72rem;
				font-weight: 700;
				padding: 0.38rem 0.48rem;
			}
			.command-search-field {
				display: grid;
				gap: 0.3rem;
				margin-top: 0.85rem;
			}
			.command-search-field input {
				background: rgba(var(--premium-ink-rgb), 68%);
				border: 1px solid var(--premium-border);
				border-radius: 10px;
				color: var(--premium-text);
				font: inherit;
				min-height: 2.7rem;
				padding: 0.55rem 0.68rem;
			}
			.command-list {
				display: grid;
				gap: 0.35rem;
				list-style: none;
				margin: 0.8rem 0 0;
				max-height: 390px;
				overflow: auto;
				padding: 0;
			}
			.command-item {
				align-items: center;
				background: transparent;
				border: 1px solid transparent;
				border-radius: 10px;
				color: var(--premium-soft);
				cursor: pointer;
				display: flex;
				font: inherit;
				gap: 1rem;
				justify-content: space-between;
				padding: 0.62rem;
				text-align: left;
				transition:
					background 140ms ease,
					border-color 140ms ease;
				width: 100%;
			}
			.command-item[aria-selected='true'],
			.command-item:hover {
				background: rgba(56, 189, 248, 10%);
				border-color: var(--premium-border-strong);
			}
			.command-item span,
			.command-item small {
				display: block;
			}
			.command-item strong {
				color: var(--premium-text);
			}
			.command-item small {
				color: var(--premium-muted);
				font-size: 0.82rem;
				line-height: 1.35;
				margin-top: 0.12rem;
			}
			.command-item em {
				font-size: 0.68rem;
				font-style: normal;
				text-transform: uppercase;
			}
			.command-empty {
				color: var(--premium-muted);
				margin: 0.8rem 0 0;
				text-align: center;
			}
			@keyframes panelEnter {
				from {
					opacity: 0;
					transform: translateY(8px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.soft-reveal {
					animation: none;
				}
				.feature-item,
				.post-item,
				.dashboard-card,
				.project-card {
					transition: none;
				}
				.command-trigger,
				.command-item {
					transition: none;
				}
			}
			@media (max-width: 820px) {
				main.space-home {
					padding-top: 1em;
				}
				.profile-cover {
					min-height: 176px;
					padding: 1.05rem;
				}
				.profile-name {
					font-size: 2.15rem;
				}
				.space-layout {
					grid-template-columns: 1fr;
				}
				.space-sidebar {
					position: static;
				}
				.space-panel {
					min-height: 0;
					padding: 1rem;
				}
				.feature-grid {
					grid-template-columns: 1fr;
				}
				.dashboard-grid,
				.project-grid,
				.post-tools,
				.interaction-grid {
					grid-template-columns: 1fr;
				}
				.filter-count {
					margin: 0;
				}
				.panel-heading {
					display: block;
				}
				.panel-link {
					display: inline-block;
					margin-top: 0.4em;
				}
				.command-shell {
					padding: 0.85rem;
				}
				.command-list {
					max-height: min(360px, 52vh);
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="space-home tech-shell visual-grid premium-shell ambient-mesh" data-space-home>
			<section class="profile-hero surface-glow executive-glass luxe-border" aria-labelledby="space-title">
				<div class="profile-cover">
					<p class="profile-kicker"><span class="signal-dot" aria-hidden="true"></span>entry developer online</p>
					<h1 id="space-title" class="profile-name">{profileName}</h1>
					<p class="profile-description">{SITE_DESCRIPTION}</p>
					<p class="code-line">~/blog $ write --learn --build --ship</p>
					<button class="command-trigger focus-ring" type="button" data-command-trigger aria-haspopup="dialog">
						<span>快速探索</span>
						<kbd>⌘ K</kbd>
					</button>
					<dl class="profile-stats" aria-label="博客统计">
						<div>
							<dt>文章</dt>
							<dd>{posts.length}</dd>
						</div>
						<div>
							<dt>分类</dt>
							<dd>{categories.length}</dd>
						</div>
						<div>
							<dt>阶段</dt>
							<dd>入门开发者</dd>
						</div>
					</dl>
					<div class="status-row" aria-label="当前学习状态">
						{
							statusItems.map((item) => (
								<div class="status-chip">
									<span>{item.label}</span>
									<strong>{item.value}</strong>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="space-layout" aria-label="博客空间内容">
				<nav class="space-sidebar executive-glass" aria-label="空间导航" role="tablist">
					{
						navItems.map((item, index) => (
							<button
								class={`space-tab focus-ring${index === 0 ? ' is-active' : ''}`}
								type="button"
								role="tab"
								aria-controls={`panel-${item.id}`}
								aria-selected={index === 0 ? 'true' : 'false'}
								data-panel-target={item.id}
							>
								<span>{item.label}</span>
								<small>{item.summary}</small>
							</button>
						))
					}
				</nav>

				<div class="space-content">
					<article class="space-panel soft-reveal is-active executive-glass" id="panel-home" role="tabpanel" data-panel="home">
						<div class="panel-heading">
							<div>
								<h2>入门开发者空间</h2>
								<p>记录从“能跑起来”到“能讲清楚”的每一次练习、部署和复盘。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/blog/')}>查看全部文章</a>
						</div>
						<div class="feature-grid">
							<div class="feature-item executive-glass">
								<h3>学习路线</h3>
								<p>把 HTML、CSS、JavaScript、Astro 和 Git 的学习顺序拆成能执行的小任务。</p>
							</div>
							<div class="feature-item executive-glass">
								<h3>项目复盘</h3>
								<p>每做完一个页面或功能，就记录目标、实现、问题和下一步改进。</p>
							</div>
							<div class="feature-item executive-glass">
								<h3>工具配置</h3>
								<p>记录 VS Code、GitHub、Chrome 调试和部署配置，方便以后快速复用。</p>
							</div>
						</div>
						<div class="dashboard-grid" aria-label="学习状态面板">
							<section class="dashboard-card executive-glass" aria-labelledby="progress-title">
								<h3 id="progress-title">学习进度</h3>
								<ul class="progress-list">
									{
										learningProgress.map((item) => (
											<li>
												<div class="progress-top">
													<span>{item.label}</span>
													<strong>{item.value}%</strong>
												</div>
												<div
													class="progress-track"
													data-progress-meter
													style={`--progress: ${item.value}%`}
													aria-label={`${item.label} ${item.value}%`}
												>
													<span></span>
												</div>
												<p class="progress-note">{item.note}</p>
											</li>
										))
									}
								</ul>
							</section>
							<section class="dashboard-card executive-glass" aria-labelledby="plan-title">
								<h3 id="plan-title">近期计划</h3>
								<ol class="plan-list">
									{currentPlans.map((plan) => <li>{plan}</li>)}
								</ol>
							</section>
						</div>
						<ul class="post-list">
							{
								recentPosts.map((post) => (
									<li class="post-item executive-glass">
										<p class="post-meta">
											{post.data.category} / <FormattedDate date={post.data.pubDate} />
										</p>
										<h3><a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a></h3>
										<p>{post.data.description}</p>
									</li>
								))
							}
						</ul>
					</article>

					<article class="space-panel soft-reveal executive-glass" id="panel-posts" role="tabpanel" data-panel="posts" hidden>
						<div class="panel-heading">
							<div>
								<h2>发布内容</h2>
								<p>文章按时间排序，主要是开发日志、踩坑记录、学习笔记和工具配置。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/blog/')}>进入文章页</a>
						</div>
						<div class="post-tools" aria-label="文章筛选工具">
							<label class="filter-field">
								<span class="tool-label">文章搜索</span>
								<input class="focus-ring" data-post-search type="search" placeholder="搜索标题、描述、标签" />
							</label>
							<label class="filter-field">
								<span class="tool-label">分类筛选</span>
								<select class="focus-ring" data-category-filter>
									<option value="">全部分类</option>
									{categories.map((category) => <option value={category}>{category}</option>)}
								</select>
							</label>
							<p class="filter-count" data-filter-count>显示 {posts.length} / {posts.length} 篇</p>
						</div>
						{
							posts.length > 0 ? (
								<ul class="post-list">
									{
										posts.map((post) => (
											<li
												class="post-item executive-glass"
												data-post-item
												data-category={post.data.category}
												data-search={`${post.data.title} ${post.data.description} ${post.data.category} ${post.data.tags.join(' ')}`}
											>
												<p class="post-meta">
													{post.data.category} / <FormattedDate date={post.data.pubDate} />
												</p>
												<h3><a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a></h3>
												<p>{post.data.description}</p>
											</li>
										))
									}
								</ul>
							) : (
								<p class="empty-state">还没有发布文章。</p>
							)
						}
						<p class="empty-state" data-filter-empty hidden>没有匹配文章，试试换个关键词或分类。</p>
					</article>

					<article class="space-panel soft-reveal executive-glass" id="panel-categories" role="tabpanel" data-panel="categories" hidden>
						<div class="panel-heading">
							<div>
								<h2>知识模块</h2>
								<p>分类对应学习和发布方向，帮助我回看每个阶段主要练了什么。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/categories/')}>查看分类页</a>
						</div>
						<ul class="category-grid">
							{
								categoryCounts.map(({ category, count }) => (
									<li>
										<button class="category-pill focus-ring" type="button" data-category-shortcut={category}>
											<strong>{category}</strong>
											<span>{count} 篇</span>
										</button>
									</li>
								))
							}
						</ul>
						<p class="empty-state">点击分类可以跳到文章面板，并自动完成分类筛选。</p>
						{
							allTags.length > 0 && (
								<>
									<h3>常用标签</h3>
									<ul class="tag-list">
										{allTags.map((tag) => <li class="tag-pill">{tag}</li>)}
									</ul>
								</>
							)
						}
					</article>

					<article class="space-panel soft-reveal executive-glass" id="panel-about" role="tabpanel" data-panel="about" hidden>
						<div class="panel-heading">
							<div>
								<h2>关于这个空间</h2>
								<p>这是一个入门开发者的公开学习仓库，用博客形式保存过程。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/about/')}>完整介绍</a>
						</div>
						<div class="about-body">
							<p>
								我会把每次学习、调试、部署和优化写成能复盘的记录。内容不追求“很高级”，
								但要尽量真实：问题是什么、怎么定位、最后怎么解决、下次如何少走弯路。
							</p>
							<section aria-labelledby="project-title">
								<h3 id="project-title">项目卡片</h3>
								<div class="project-grid">
									{
										projectCards.map((project) => (
											<article class="project-card executive-glass" data-project-card>
												<div class="project-head">
													<h4>{project.name}</h4>
													<span class="project-status">{project.status}</span>
												</div>
												<p>{project.description}</p>
											</article>
										))
									}
								</div>
							</section>
							<section class="tech-stack" aria-labelledby="stack-title">
								<h3 id="stack-title">技术栈</h3>
								<ul class="tag-list">
									{techStack.map((tech) => <li class="tag-pill">{tech}</li>)}
								</ul>
							</section>
							<section class="interaction-card executive-glass" aria-labelledby="interaction-title" data-local-interactions>
								<h3 id="interaction-title">访客互动台</h3>
								<p class="interaction-note">
									这里先做静态博客可用的本地互动：访客昵称、本地点赞、本地收藏和留言草稿都会保存在当前浏览器。
								</p>
								<div class="interaction-grid">
									<label class="interaction-field">
										<span class="tool-label">访客昵称</span>
										<input
											class="focus-ring"
											data-visitor-name
											type="text"
											maxlength="20"
											placeholder="例如：学习中的访客"
										/>
									</label>
									<div class="interaction-field">
										<span class="tool-label">本地状态</span>
										<div class="interaction-actions">
											<button class="interaction-button focus-ring" type="button" data-like-button>
												本地点赞 <span data-like-count>0</span>
											</button>
											<button class="interaction-button focus-ring" type="button" data-favorite-button>
												本地收藏
											</button>
										</div>
									</div>
									<label class="interaction-field full">
										<span class="tool-label">留言草稿</span>
										<textarea
											class="focus-ring"
											data-comment-draft
											maxlength="240"
											placeholder="写下想对这个博客说的话；当前版本只保存在你的浏览器里。"
										></textarea>
									</label>
									<div class="interaction-field full">
										<span class="tool-label">草稿预览 <strong class="local-badge">LOCAL ONLY</strong></span>
										<p class="comment-preview" data-comment-preview>还没有留言草稿。</p>
									</div>
								</div>
							</section>
							<div class="about-actions">
								<a class="button focus-ring" href={withBase('/blog/')}>阅读开发日志</a>
								<a class="button secondary focus-ring" href={withBase('/about/')}>了解学习路线</a>
							</div>
						</div>
					</article>
				</div>
			</section>

			<dialog class="command-dialog" data-command-dialog aria-labelledby="command-title">
				<div class="command-shell">
					<header class="command-header">
						<div>
							<p class="command-kicker">COMMAND CENTER</p>
							<h2 id="command-title">快速探索</h2>
						</div>
						<button class="command-close focus-ring" type="button" data-command-close aria-label="关闭快速探索">
							ESC
						</button>
					</header>
					<label class="command-search-field">
						<span class="tool-label">搜索</span>
						<input
							class="focus-ring"
							type="search"
							role="combobox"
							aria-controls="command-list"
							aria-autocomplete="list"
							aria-expanded="true"
							data-command-search
							placeholder="搜索面板、分类或文章"
							autocomplete="off"
						/>
					</label>
					<ul class="command-list" id="command-list" data-command-list role="listbox" aria-label="探索结果">
						{
							commandItems.map((item, index) => (
								<li>
									<button
										id={`command-item-${index}`}
										class="command-item focus-ring"
										type="button"
										role="option"
										aria-selected={index === 0 ? 'true' : 'false'}
										data-command-item
										data-command-kind={item.kind}
										data-command-target={item.target}
										data-command-href={item.href}
										data-command-search={item.search}
									>
										<span>
											<strong>{item.label}</strong>
											<small>{item.description}</small>
										</span>
										<em>{item.kind}</em>
									</button>
								</li>
							))
						}
					</ul>
					<p class="command-empty" data-command-empty hidden>没有匹配结果，换个关键词试试。</p>
				</div>
			</dialog>
		</main>
		<Footer />
		<script is:inline>
			const commandTrigger = document.querySelector('[data-command-trigger]');
			const commandDialog = document.querySelector('[data-command-dialog]');
			const commandClose = document.querySelector('[data-command-close]');
			const commandSearch = document.querySelector('[data-command-search]');
			const commandEmpty = document.querySelector('[data-command-empty]');
			const commandItems = Array.from(document.querySelectorAll('[data-command-item]'));
			const tabs = Array.from(document.querySelectorAll('[data-panel-target]'));
			const panels = Array.from(document.querySelectorAll('[data-panel]'));
			const postSearch = document.querySelector('[data-post-search]');
			const categoryFilter = document.querySelector('[data-category-filter]');
			const filterCount = document.querySelector('[data-filter-count]');
			const filterEmpty = document.querySelector('[data-filter-empty]');
			const postItems = Array.from(document.querySelectorAll('[data-post-item]'));
			const categoryShortcuts = Array.from(document.querySelectorAll('[data-category-shortcut]'));
			const visitorName = document.querySelector('[data-visitor-name]');
			const likeButton = document.querySelector('[data-like-button]');
			const likeCount = document.querySelector('[data-like-count]');
			const favoriteButton = document.querySelector('[data-favorite-button]');
			const commentDraft = document.querySelector('[data-comment-draft]');
			const commentPreview = document.querySelector('[data-comment-preview]');
			const visitorStorageKey = 'hilavera-blog-visitor-state';
			let activeCommandIndex = 0;

			function normalizeText(value) {
				return String(value || '').trim().toLowerCase();
			}

			function visibleCommandItems() {
				return commandItems.filter((item) => !item.hidden);
			}

			function setActiveCommand(index) {
				const visibleItems = visibleCommandItems();
				if (!visibleItems.length) {
					commandSearch?.removeAttribute('aria-activedescendant');
					return;
				}

				activeCommandIndex = (index + visibleItems.length) % visibleItems.length;
				visibleItems.forEach((item, itemIndex) => {
					item.setAttribute('aria-selected', String(itemIndex === activeCommandIndex));
				});
				commandSearch?.setAttribute('aria-activedescendant', visibleItems[activeCommandIndex].id);
				visibleItems[activeCommandIndex]?.scrollIntoView({ block: 'nearest' });
			}

			function filterCommandItems() {
				const query = normalizeText(commandSearch?.value);
				commandItems.forEach((item) => {
					item.hidden = Boolean(query) && !normalizeText(item.dataset.commandSearch).includes(query);
				});
				if (commandEmpty) commandEmpty.hidden = visibleCommandItems().length !== 0;
				setActiveCommand(0);
			}

			function openCommandCenter() {
				if (!commandDialog || commandDialog.open) return;
				commandDialog.showModal();
				commandSearch?.focus();
				filterCommandItems();
			}

			function closeCommandCenter() {
				commandDialog?.close();
				commandTrigger?.focus();
			}

			function runCommand(item) {
				if (item.dataset.commandKind === 'panel') {
					showPanel(item.dataset.commandTarget, { focusPanel: true });
				} else if (item.dataset.commandKind === 'category') {
					if (categoryFilter) categoryFilter.value = item.dataset.commandTarget || '';
					showPanel('posts', { focusPanel: true });
					filterPosts();
				} else if (item.dataset.commandHref) {
					window.location.assign(item.dataset.commandHref);
					return;
				}
				closeCommandCenter();
			}

			function readVisitorState() {
				try {
					const savedState = window.localStorage.getItem(visitorStorageKey);
					return savedState
						? JSON.parse(savedState)
						: { name: '', liked: false, favorite: false, likes: 0, comment: '' };
				} catch {
					return { name: '', liked: false, favorite: false, likes: 0, comment: '' };
				}
			}

			function writeVisitorState(state) {
				window.localStorage.setItem(visitorStorageKey, JSON.stringify(state));
			}

			function getVisitorStateFromInputs() {
				return {
					...readVisitorState(),
					name: visitorName?.value.trim() || '',
					comment: commentDraft?.value.trim() || '',
				};
			}

			function updateVisitorState(state = readVisitorState()) {
				if (visitorName) visitorName.value = state.name || '';
				if (commentDraft) commentDraft.value = state.comment || '';
				if (likeCount) likeCount.textContent = String(state.likes || 0);
				if (commentPreview) {
					const visitorLabel = state.name ? `${state.name}：` : '';
					commentPreview.textContent = state.comment ? `${visitorLabel}${state.comment}` : '还没有留言草稿。';
				}
				likeButton?.classList.toggle('is-active', Boolean(state.liked));
				favoriteButton?.classList.toggle('is-active', Boolean(state.favorite));
				likeButton?.setAttribute('aria-pressed', String(Boolean(state.liked)));
				favoriteButton?.setAttribute('aria-pressed', String(Boolean(state.favorite)));
			}

			function saveCommentDraft() {
				const nextState = getVisitorStateFromInputs();
				writeVisitorState(nextState);
				updateVisitorState(nextState);
			}

			function showPanel(panelId) {
				tabs.forEach((tab) => {
					const isActive = tab.dataset.panelTarget === panelId;
					tab.classList.toggle('is-active', isActive);
					tab.setAttribute('aria-selected', String(isActive));
				});

				panels.forEach((panel) => {
					const isActive = panel.dataset.panel === panelId;
					panel.classList.toggle('is-active', isActive);
					panel.toggleAttribute('hidden', !isActive);
					if (isActive) {
						panel.classList.remove('soft-reveal');
						void panel.offsetWidth;
						panel.classList.add('soft-reveal');
					}
				});

				if (window.history.replaceState) {
					window.history.replaceState(null, '', `#${panelId}`);
				}
			}

			function filterPosts() {
				const query = normalizeText(postSearch?.value);
				const selectedCategory = categoryFilter?.value || '';
				let visibleCount = 0;

				postItems.forEach((item) => {
					const matchesQuery = !query || normalizeText(item.dataset.search).includes(query);
					const matchesCategory = !selectedCategory || item.dataset.category === selectedCategory;
					const isVisible = matchesQuery && matchesCategory;

					item.classList.toggle('is-hidden', !isVisible);
					if (isVisible) visibleCount += 1;
				});

				if (filterCount) {
					filterCount.textContent = `显示 ${visibleCount} / ${postItems.length} 篇`;
				}

				if (filterEmpty) {
					filterEmpty.hidden = visibleCount !== 0;
				}
			}

			commandTrigger?.addEventListener('click', openCommandCenter);
			commandClose?.addEventListener('click', closeCommandCenter);
			commandDialog?.addEventListener('cancel', (event) => {
				event.preventDefault();
				closeCommandCenter();
			});
			commandSearch?.addEventListener('input', filterCommandItems);
			commandSearch?.addEventListener('keydown', (event) => {
				if (event.key === 'ArrowDown' || event.key === 'ArrowUp') {
					event.preventDefault();
					setActiveCommand(activeCommandIndex + (event.key === 'ArrowDown' ? 1 : -1));
				}
				if (event.key === 'Enter') {
					event.preventDefault();
					const selectedItem = visibleCommandItems()[activeCommandIndex];
					if (selectedItem) runCommand(selectedItem);
				}
			});
			commandItems.forEach((item) => item.addEventListener('click', () => runCommand(item)));
			document.addEventListener('keydown', (event) => {
				if ((event.metaKey || event.ctrlKey) && event.key.toLowerCase() === 'k') {
					event.preventDefault();
					openCommandCenter();
				}
				if (event.key === 'Escape' && commandDialog?.open) closeCommandCenter();
			});

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => showPanel(tab.dataset.panelTarget));
			});

			postSearch?.addEventListener('input', filterPosts);
			categoryFilter?.addEventListener('change', filterPosts);
			visitorName?.addEventListener('input', saveCommentDraft);
			commentDraft?.addEventListener('input', saveCommentDraft);

			likeButton?.addEventListener('click', () => {
				const nextState = getVisitorStateFromInputs();
				nextState.liked = !nextState.liked;
				nextState.likes = nextState.liked ? 1 : 0;
				writeVisitorState(nextState);
				updateVisitorState(nextState);
			});

			favoriteButton?.addEventListener('click', () => {
				const nextState = getVisitorStateFromInputs();
				nextState.favorite = !nextState.favorite;
				writeVisitorState(nextState);
				updateVisitorState(nextState);
			});

			categoryShortcuts.forEach((button) => {
				button.addEventListener('click', () => {
					if (categoryFilter) {
						categoryFilter.value = button.dataset.categoryShortcut || '';
					}
					showPanel('posts');
					filterPosts();
					postSearch?.focus();
				});
			});

			const initialPanel = window.location.hash.replace('#', '');
			if (tabs.some((tab) => tab.dataset.panelTarget === initialPanel)) {
				showPanel(initialPanel);
			}

			filterPosts();
			updateVisitorState();
		</script>
	</body>
</html>
