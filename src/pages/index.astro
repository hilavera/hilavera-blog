---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
const categories = Array.from(new Set(posts.map((post) => post.data.category)));
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 960px;
			}
			.hero {
				padding: 3em 0 2em;
			}
			.hero p {
				max-width: 680px;
				font-size: 1.1em;
			}
			.actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.75em;
				margin-top: 1.5em;
			}
			.button {
				background: var(--accent);
				border: 1px solid var(--accent);
				border-radius: 8px;
				color: white;
				display: inline-block;
				font-weight: 700;
				padding: 0.55em 0.9em;
				text-decoration: none;
			}
			.button.secondary {
				background: white;
				color: var(--accent);
			}
			.section-title {
				align-items: baseline;
				border-top: 1px solid rgb(var(--gray-light));
				display: flex;
				justify-content: space-between;
				margin-top: 2em;
				padding-top: 2em;
			}
			.post-list,
			.category-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-list {
				display: grid;
				gap: 1em;
			}
			.post-card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				padding: 1em;
			}
			.post-card h3 {
				font-size: 1.25em;
			}
			.post-card a {
				color: rgb(var(--black));
				text-decoration: none;
			}
			.post-card a:hover {
				color: var(--accent);
			}
			.post-meta {
				color: rgb(var(--gray));
				font-size: 0.85em;
				margin: 0;
			}
			.category-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5em;
			}
			.category-list li {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				padding: 0.15em 0.7em;
			}
			@media (max-width: 720px) {
				.section-title {
					align-items: flex-start;
					flex-direction: column;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="home">
			<section class="hero">
				<h1>把技术、生活和阅读都认真记录下来。</h1>
				<p>{SITE_DESCRIPTION}</p>
				<div class="actions">
					<a class="button" href={withBase('/blog/')}>查看文章</a>
					<a class="button secondary" href={withBase('/about/')}>关于这个博客</a>
				</div>
			</section>

			<section>
				<div class="section-title">
					<h2>最近文章</h2>
					<a href={withBase('/blog/')}>全部文章</a>
				</div>
				<ul class="post-list">
					{
						recentPosts.map((post) => (
							<li class="post-card">
								<p class="post-meta">
									{post.data.category} / <FormattedDate date={post.data.pubDate} />
								</p>
								<h3><a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a></h3>
								<p>{post.data.description}</p>
							</li>
						))
					}
				</ul>
			</section>

			<section>
				<div class="section-title">
					<h2>分类</h2>
					<a href={withBase('/categories/')}>查看标签</a>
				</div>
				<ul class="category-list">
					{categories.map((category) => <li>{category}</li>)}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
