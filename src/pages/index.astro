---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { getCollection } from 'astro:content';
import { SITE_DESCRIPTION, SITE_TITLE, withBase } from '../consts';

const profileName = 'hilavera';
const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const recentPosts = posts.slice(0, 3);
const categories = Array.from(new Set(posts.map((post) => post.data.category)));
const categoryCounts = categories.map((category) => ({
	category,
	count: posts.filter((post) => post.data.category === category).length,
}));
const allTags = Array.from(new Set(posts.flatMap((post) => post.data.tags))).slice(0, 8);

const navItems = [
	{ id: 'home', label: '主页', summary: '开发者状态' },
	{ id: 'posts', label: '文章', summary: '发布记录' },
	{ id: 'categories', label: '分类', summary: '知识模块' },
	{ id: 'about', label: '关于', summary: '学习路线' },
];

const statusItems = [
	{ label: 'NOW', value: 'Astro + GitHub Pages' },
	{ label: 'LEARNING', value: 'JavaScript / CSS / Markdown' },
	{ label: 'NEXT', value: 'TypeScript 基础和组件拆分' },
];

const learningProgress = [
	{ label: 'HTML / CSS 页面结构', value: 72, note: '能搭出稳定布局，继续练响应式和细节还原。' },
	{ label: 'JavaScript 基础交互', value: 48, note: '能写切换、筛选、状态更新这类小功能。' },
	{ label: 'Astro 博客发布', value: 82, note: '已完成 GitHub Pages 发布，继续补内容和 SEO。' },
];

const currentPlans = [
	'把首页做成可搜索、可筛选的个人开发空间。',
	'每周至少写一篇开发日志，记录真实问题和解决过程。',
	'补 TypeScript 基础，下一步尝试把页面组件拆得更清楚。',
];

const projectCards = [
	{
		name: 'hilavera-blog',
		status: '已上线',
		description: '用 Astro + GitHub Pages 搭建的个人博客，当前重点是内容结构和首页体验。',
	},
	{
		name: '开发日志系统',
		status: '持续更新',
		description: '把学习路线、踩坑记录、项目复盘写成可回看的文章。',
	},
	{
		name: '前端练习清单',
		status: '准备中',
		description: '后续用小组件练习 HTML、CSS、JavaScript 和 TypeScript。',
	},
];

const techStack = ['Astro', 'HTML', 'CSS', 'JavaScript', 'Markdown', 'Git', 'GitHub Pages', 'Chrome DevTools'];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				background:
					radial-gradient(circle at 12% 0%, rgba(34, 211, 238, 18%), transparent 28rem),
					radial-gradient(circle at 88% 8%, rgba(20, 184, 166, 18%), transparent 30rem),
					linear-gradient(180deg, #07111f 0%, #0b1220 48%, #111827 100%);
				color: #d8e8f8;
			}
			main.space-home {
				width: min(1040px, calc(100% - 2rem));
				max-width: calc(100% - 2rem);
				isolation: isolate;
				padding: 1.5rem 0 3.2rem;
			}
			.tech-shell {
				position: relative;
			}
			.visual-grid::before,
			.visual-grid::after {
				content: '';
				inset: -1.5rem;
				pointer-events: none;
				position: absolute;
				z-index: 0;
			}
			.visual-grid::before {
				animation: scanDrift 18s linear infinite;
				background:
					repeating-linear-gradient(
						0deg,
						rgba(125, 211, 252, 6%) 0,
						rgba(125, 211, 252, 6%) 1px,
						transparent 1px,
						transparent 18px
					),
					linear-gradient(120deg, transparent 10%, rgba(34, 211, 238, 10%) 50%, transparent 88%);
				opacity: 0.28;
			}
			.visual-grid::after {
				background:
					linear-gradient(90deg, transparent, rgba(20, 184, 166, 10%), transparent),
					radial-gradient(ellipse at 50% 0%, rgba(34, 211, 238, 10%), transparent 58%);
				filter: blur(0.2px);
				opacity: 0.55;
			}
			.profile-hero,
			.space-layout {
				position: relative;
				z-index: 1;
			}
			.profile-hero {
				background:
					linear-gradient(135deg, rgba(15, 23, 42, 95%) 0%, rgba(12, 74, 110, 82%) 58%, rgba(6, 78, 59, 72%) 100%),
					linear-gradient(90deg, rgba(34, 211, 238, 28%), rgba(20, 184, 166, 12%));
				border: 1px solid rgba(125, 211, 252, 24%);
				border-radius: 8px;
				box-shadow: 0 20px 60px rgba(8, 47, 73, 28%);
				margin-bottom: 1rem;
				overflow: hidden;
				position: relative;
			}
			.profile-hero::before {
				background-image:
					linear-gradient(rgba(125, 211, 252, 10%) 1px, transparent 1px),
					linear-gradient(90deg, rgba(125, 211, 252, 10%) 1px, transparent 1px);
				background-size: 36px 36px;
				content: '';
				inset: 0;
				opacity: 0.42;
				position: absolute;
			}
			.profile-hero.surface-glow::after {
				background: linear-gradient(120deg, transparent 8%, rgba(255, 255, 255, 14%) 44%, transparent 72%);
				content: '';
				inset: 0;
				opacity: 0.35;
				position: absolute;
				transform: translateX(-55%);
			}
			.profile-cover {
				min-height: 210px;
				padding: 1.55rem 1.7rem;
				position: relative;
				z-index: 1;
			}
			.profile-cover::after {
				background: linear-gradient(90deg, #22d3ee, #14b8a6, transparent);
				bottom: 0;
				content: '';
				height: 3px;
				left: 0;
				position: absolute;
				right: 0;
			}
			.profile-kicker,
			.code-line {
				align-items: center;
				color: #67e8f9;
				display: inline-flex;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.76rem;
				font-weight: 700;
				gap: 0.45rem;
				letter-spacing: 0.06em;
				margin: 0 0 0.55rem;
				text-transform: uppercase;
			}
			.signal-dot {
				animation: signalPulse 2.6s ease-in-out infinite;
				background: #22c55e;
				border-radius: 999px;
				box-shadow: 0 0 18px rgba(34, 197, 94, 90%);
				display: inline-block;
				height: 0.55rem;
				width: 0.55rem;
			}
			.profile-name {
				color: #f8fafc;
				font-size: 2.9rem;
				letter-spacing: 0;
				line-height: 1.05;
				margin-bottom: 0.3rem;
			}
			.profile-description {
				color: #cbd5e1;
				font-size: 0.98rem;
				line-height: 1.65;
				max-width: 640px;
				margin: 0;
			}
			.code-line {
				margin-top: 0.75rem;
			}
			.profile-stats,
			.status-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
				margin: 1.05rem 0 0;
			}
			.profile-stats div,
			.status-chip {
				background: rgba(15, 23, 42, 72%);
				border: 1px solid rgba(125, 211, 252, 22%);
				border-radius: 8px;
				box-shadow: inset 0 1px 0 rgba(255, 255, 255, 8%);
				padding: 0.48rem 0.65rem;
			}
			.profile-stats div {
				min-width: 96px;
			}
			.status-chip {
				flex: 1 1 178px;
				min-width: 0;
			}
			.profile-stats dt,
			.status-chip span {
				color: #67e8f9;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.08em;
			}
			.profile-stats dd,
			.status-chip strong {
				color: #f8fafc;
				display: block;
				font-size: 0.92rem;
				font-weight: 700;
				margin: 0.05rem 0 0;
			}
			.space-layout {
				align-items: start;
				display: grid;
				gap: 1rem;
				grid-template-columns: 196px minmax(0, 1fr);
			}
			.space-sidebar,
			.space-panel {
				background: rgba(15, 23, 42, 88%);
				border: 1px solid rgba(125, 211, 252, 18%);
				box-shadow: 0 16px 50px rgba(2, 6, 23, 32%);
				backdrop-filter: blur(14px);
			}
			.space-sidebar {
				border-radius: 8px;
				display: grid;
				gap: 0.35rem;
				padding: 0.55rem;
				position: sticky;
				top: 1em;
			}
			.space-tab {
				background: transparent;
				border: 1px solid transparent;
				border-radius: 8px;
				color: #cbd5e1;
				cursor: pointer;
				display: grid;
				font: inherit;
				gap: 0.08rem;
				padding: 0.58rem 0.68rem;
				text-align: left;
				width: 100%;
			}
			.space-tab:hover,
			.space-tab.is-active {
				background:
					linear-gradient(90deg, rgba(34, 211, 238, 18%), transparent),
					rgba(8, 145, 178, 18%);
				border-color: rgba(34, 211, 238, 28%);
				color: #f8fafc;
			}
			.focus-ring:focus-visible {
				box-shadow: 0 0 0 3px rgba(34, 211, 238, 18%);
				outline: 1px solid rgba(125, 211, 252, 62%);
				outline-offset: 2px;
			}
			.space-tab span {
				font-weight: 700;
				line-height: 1.2;
			}
			.space-tab small {
				color: #94a3b8;
				font-size: 0.75rem;
				line-height: 1.3;
			}
			.space-content {
				min-width: 0;
			}
			.space-panel {
				border-radius: 8px;
				min-height: 380px;
				overflow: hidden;
				padding: 1.15rem;
				position: relative;
			}
			.space-panel::before {
				background: linear-gradient(90deg, rgba(34, 211, 238, 0%), rgba(34, 211, 238, 62%), rgba(20, 184, 166, 0%));
				content: '';
				height: 1px;
				left: 0.9rem;
				opacity: 0.6;
				position: absolute;
				right: 0.9rem;
				top: 0;
			}
			.space-panel > * {
				position: relative;
				z-index: 1;
			}
			.soft-reveal {
				animation: panelEnter 220ms ease-out both;
			}
			.space-panel[hidden] {
				display: none;
			}
			.panel-heading {
				align-items: start;
				border-bottom: 1px solid rgba(125, 211, 252, 16%);
				display: flex;
				gap: 0.85rem;
				justify-content: space-between;
				margin-bottom: 0.95rem;
				padding-bottom: 0.68rem;
			}
			.panel-heading h2 {
				color: #f8fafc;
				font-size: 1.48rem;
				line-height: 1.2;
			}
			.panel-heading p,
			.feature-item p,
			.post-item p,
			.about-body p {
				color: #cbd5e1;
				margin: 0;
			}
			.panel-link,
			.post-item a,
			.category-pill {
				color: #67e8f9;
			}
			.panel-link {
				font-size: 0.86rem;
				font-weight: 700;
				white-space: nowrap;
			}
			.feature-grid {
				display: grid;
				gap: 0.68rem;
				grid-template-columns: repeat(3, minmax(0, 1fr));
				margin-bottom: 0.95rem;
			}
			.feature-item,
			.post-item {
				background: rgba(2, 6, 23, 32%);
				border: 1px solid rgba(125, 211, 252, 16%);
				border-radius: 8px;
				padding: 0.72rem;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					background 160ms ease,
					transform 160ms ease;
			}
			.feature-item:hover,
			.post-item:hover,
			.dashboard-card:hover,
			.project-card:hover {
				border-color: rgba(34, 211, 238, 38%);
				box-shadow:
					0 10px 30px rgba(8, 145, 178, 16%),
					inset 0 1px 0 rgba(255, 255, 255, 8%);
				transform: translateY(-1px);
			}
			.feature-item h3,
			.post-item h3 {
				color: #f8fafc;
				font-size: 1.02rem;
				line-height: 1.3;
				margin-bottom: 0.28rem;
			}
			.post-list {
				display: grid;
				gap: 0.68rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.post-item a {
				text-decoration: none;
			}
			.post-item a:hover {
				color: #a7f3d0;
			}
			.post-meta {
				color: #94a3b8;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.78rem;
				margin: 0 0 0.2rem;
			}
			.dashboard-grid,
			.project-grid {
				display: grid;
				gap: 0.68rem;
				grid-template-columns: repeat(2, minmax(0, 1fr));
				margin: 0.95rem 0;
			}
			.dashboard-card,
			.project-card {
				background:
					linear-gradient(135deg, rgba(8, 47, 73, 42%), rgba(2, 6, 23, 28%)),
					rgba(2, 6, 23, 36%);
				border: 1px solid rgba(125, 211, 252, 18%);
				border-radius: 8px;
				padding: 0.82rem;
				transition:
					border-color 160ms ease,
					box-shadow 160ms ease,
					background 160ms ease,
					transform 160ms ease;
			}
			.dashboard-card h3,
			.project-card h3,
			.interaction-card h3,
			.about-body h3 {
				color: #f8fafc;
				font-size: 1.02rem;
				line-height: 1.3;
				margin-bottom: 0.5rem;
			}
			.progress-list,
			.plan-list,
			.project-list {
				display: grid;
				gap: 0.7rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.progress-top,
			.project-head {
				align-items: center;
				display: flex;
				gap: 0.7rem;
				justify-content: space-between;
			}
			.progress-top span,
			.project-head h4 {
				color: #e0f2fe;
				font-size: 0.92rem;
				font-weight: 700;
				margin: 0;
			}
			.progress-top strong,
			.project-status {
				color: #67e8f9;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.76rem;
			}
			.progress-track {
				background: rgba(15, 23, 42, 85%);
				border: 1px solid rgba(125, 211, 252, 16%);
				border-radius: 999px;
				height: 0.46rem;
				margin: 0.35rem 0;
				overflow: hidden;
			}
			.progress-track span {
				background: linear-gradient(90deg, #22d3ee, #14b8a6);
				border-radius: inherit;
				box-shadow: 0 0 18px rgba(34, 211, 238, 42%);
				display: block;
				height: 100%;
				width: var(--progress);
			}
			.progress-note,
			.project-card p {
				color: #cbd5e1;
				font-size: 0.88rem;
				line-height: 1.55;
				margin: 0;
			}
			.interaction-card {
				background:
					linear-gradient(135deg, rgba(14, 116, 144, 28%), rgba(2, 6, 23, 36%)),
					rgba(2, 6, 23, 38%);
				border: 1px solid rgba(125, 211, 252, 20%);
				border-radius: 8px;
				padding: 0.82rem;
			}
			.interaction-note {
				color: #94a3b8;
				font-size: 0.84rem;
				line-height: 1.55;
				margin-bottom: 0.75rem;
			}
			.interaction-grid {
				display: grid;
				gap: 0.68rem;
				grid-template-columns: 1fr 1fr;
			}
			.interaction-field {
				display: grid;
				gap: 0.3rem;
			}
			.interaction-field.full {
				grid-column: 1 / -1;
			}
			.interaction-field input,
			.interaction-field textarea {
				background: rgba(2, 6, 23, 55%);
				border: 1px solid rgba(125, 211, 252, 24%);
				border-radius: 8px;
				color: #f8fafc;
				font: inherit;
				font-size: 0.92rem;
				padding: 0.48rem 0.62rem;
			}
			.interaction-field textarea {
				min-height: 5.5rem;
				resize: vertical;
			}
			.interaction-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem;
			}
			.interaction-button {
				background: rgba(15, 23, 42, 76%);
				border: 1px solid rgba(125, 211, 252, 24%);
				border-radius: 8px;
				color: #cbd5e1;
				cursor: pointer;
				font: inherit;
				font-weight: 700;
				padding: 0.46rem 0.72rem;
			}
			.interaction-button.is-active {
				background: linear-gradient(135deg, rgba(8, 145, 178, 74%), rgba(20, 184, 166, 64%));
				border-color: rgba(34, 211, 238, 58%);
				color: #f8fafc;
			}
			.comment-preview {
				background: rgba(2, 6, 23, 34%);
				border: 1px dashed rgba(125, 211, 252, 20%);
				border-radius: 8px;
				color: #cbd5e1;
				font-size: 0.88rem;
				line-height: 1.55;
				min-height: 2.4rem;
				padding: 0.62rem;
				white-space: pre-wrap;
			}
			.local-badge {
				color: #67e8f9;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.72rem;
			}
			.plan-list {
				counter-reset: plan;
			}
			.plan-list li {
				color: #cbd5e1;
				line-height: 1.55;
				padding-left: 2rem;
				position: relative;
			}
			.plan-list li::before {
				background: rgba(34, 211, 238, 16%);
				border: 1px solid rgba(34, 211, 238, 28%);
				border-radius: 999px;
				color: #67e8f9;
				content: counter(plan, decimal-leading-zero);
				counter-increment: plan;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.68rem;
				font-weight: 700;
				left: 0;
				line-height: 1.35rem;
				position: absolute;
				text-align: center;
				top: 0.1rem;
				width: 1.35rem;
			}
			.post-tools {
				align-items: end;
				display: grid;
				gap: 0.68rem;
				grid-template-columns: minmax(0, 1fr) 180px auto;
				margin-bottom: 0.9rem;
			}
			.filter-field {
				display: grid;
				gap: 0.3rem;
			}
			.tool-label,
			.filter-count {
				color: #67e8f9;
				font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
				font-size: 0.72rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				text-transform: uppercase;
			}
			.filter-field input,
			.filter-field select {
				background: rgba(2, 6, 23, 55%);
				border: 1px solid rgba(125, 211, 252, 24%);
				border-radius: 8px;
				color: #f8fafc;
				font: inherit;
				font-size: 0.92rem;
				min-height: 2.25rem;
				padding: 0.45rem 0.62rem;
			}
			.filter-field input:focus,
			.filter-field select:focus {
				border-color: rgba(34, 211, 238, 72%);
				box-shadow: 0 0 0 3px rgba(34, 211, 238, 12%);
				outline: none;
			}
			.filter-count {
				margin: 0 0 0.42rem;
				white-space: nowrap;
			}
			.post-item.is-hidden {
				display: none;
			}
			.category-grid,
			.tag-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.category-pill,
			.tag-pill {
				background: rgba(8, 47, 73, 36%);
				border: 1px solid rgba(125, 211, 252, 18%);
				border-radius: 999px;
				display: inline-flex;
				gap: 0.38rem;
				padding: 0.22rem 0.68rem;
				text-decoration: none;
			}
			button.category-pill {
				color: #67e8f9;
				cursor: pointer;
				font: inherit;
			}
			.category-pill strong {
				color: #f8fafc;
			}
			.category-pill span,
			.tag-pill {
				color: #bae6fd;
				font-size: 0.85rem;
			}
			.about-body {
				display: grid;
				gap: 0.85rem;
			}
			.tech-stack {
				margin-top: 0.1rem;
			}
			.about-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.6rem;
			}
			.button {
				background: linear-gradient(135deg, #0891b2, #14b8a6);
				border: 1px solid rgba(125, 211, 252, 36%);
				border-radius: 8px;
				color: white;
				display: inline-block;
				font-weight: 700;
				padding: 0.46rem 0.78rem;
				text-decoration: none;
			}
			.button.secondary {
				background: rgba(15, 23, 42, 80%);
				color: #67e8f9;
			}
			.empty-state {
				color: #94a3b8;
			}
			@keyframes panelEnter {
				from {
					opacity: 0;
					transform: translateY(8px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			@keyframes scanDrift {
				from {
					background-position:
						0 0,
						0 0;
				}
				to {
					background-position:
						0 54px,
						160px 0;
				}
			}
			@keyframes signalPulse {
				0%,
				100% {
					box-shadow: 0 0 12px rgba(34, 197, 94, 72%);
				}
				50% {
					box-shadow: 0 0 24px rgba(34, 197, 94, 95%);
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.visual-grid::before,
				.signal-dot,
				.soft-reveal {
					animation: none;
				}
				.feature-item,
				.post-item,
				.dashboard-card,
				.project-card {
					transition: none;
				}
			}
			@media (max-width: 820px) {
				main.space-home {
					padding-top: 1em;
				}
				.profile-cover {
					min-height: 176px;
					padding: 1.05rem;
				}
				.profile-name {
					font-size: 2.15rem;
				}
				.space-layout {
					grid-template-columns: 1fr;
				}
				.space-sidebar {
					position: static;
				}
				.space-panel {
					min-height: 0;
					padding: 1rem;
				}
				.feature-grid {
					grid-template-columns: 1fr;
				}
				.dashboard-grid,
				.project-grid,
				.post-tools,
				.interaction-grid {
					grid-template-columns: 1fr;
				}
				.filter-count {
					margin: 0;
				}
				.panel-heading {
					display: block;
				}
				.panel-link {
					display: inline-block;
					margin-top: 0.4em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="space-home tech-shell visual-grid" data-space-home>
			<section class="profile-hero surface-glow" aria-labelledby="space-title">
				<div class="profile-cover">
					<p class="profile-kicker"><span class="signal-dot" aria-hidden="true"></span>entry developer online</p>
					<h1 id="space-title" class="profile-name">{profileName}</h1>
					<p class="profile-description">{SITE_DESCRIPTION}</p>
					<p class="code-line">~/blog $ write --learn --build --ship</p>
					<dl class="profile-stats" aria-label="博客统计">
						<div>
							<dt>文章</dt>
							<dd>{posts.length}</dd>
						</div>
						<div>
							<dt>分类</dt>
							<dd>{categories.length}</dd>
						</div>
						<div>
							<dt>阶段</dt>
							<dd>入门开发者</dd>
						</div>
					</dl>
					<div class="status-row" aria-label="当前学习状态">
						{
							statusItems.map((item) => (
								<div class="status-chip">
									<span>{item.label}</span>
									<strong>{item.value}</strong>
								</div>
							))
						}
					</div>
				</div>
			</section>

			<section class="space-layout" aria-label="博客空间内容">
				<nav class="space-sidebar" aria-label="空间导航" role="tablist">
					{
						navItems.map((item, index) => (
							<button
								class={`space-tab focus-ring${index === 0 ? ' is-active' : ''}`}
								type="button"
								role="tab"
								aria-controls={`panel-${item.id}`}
								aria-selected={index === 0 ? 'true' : 'false'}
								data-panel-target={item.id}
							>
								<span>{item.label}</span>
								<small>{item.summary}</small>
							</button>
						))
					}
				</nav>

				<div class="space-content">
					<article class="space-panel soft-reveal is-active" id="panel-home" role="tabpanel" data-panel="home">
						<div class="panel-heading">
							<div>
								<h2>入门开发者空间</h2>
								<p>记录从“能跑起来”到“能讲清楚”的每一次练习、部署和复盘。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/blog/')}>查看全部文章</a>
						</div>
						<div class="feature-grid">
							<div class="feature-item">
								<h3>学习路线</h3>
								<p>把 HTML、CSS、JavaScript、Astro 和 Git 的学习顺序拆成能执行的小任务。</p>
							</div>
							<div class="feature-item">
								<h3>项目复盘</h3>
								<p>每做完一个页面或功能，就记录目标、实现、问题和下一步改进。</p>
							</div>
							<div class="feature-item">
								<h3>工具配置</h3>
								<p>记录 VS Code、GitHub、Chrome 调试和部署配置，方便以后快速复用。</p>
							</div>
						</div>
						<div class="dashboard-grid" aria-label="学习状态面板">
							<section class="dashboard-card" aria-labelledby="progress-title">
								<h3 id="progress-title">学习进度</h3>
								<ul class="progress-list">
									{
										learningProgress.map((item) => (
											<li>
												<div class="progress-top">
													<span>{item.label}</span>
													<strong>{item.value}%</strong>
												</div>
												<div
													class="progress-track"
													data-progress-meter
													style={`--progress: ${item.value}%`}
													aria-label={`${item.label} ${item.value}%`}
												>
													<span></span>
												</div>
												<p class="progress-note">{item.note}</p>
											</li>
										))
									}
								</ul>
							</section>
							<section class="dashboard-card" aria-labelledby="plan-title">
								<h3 id="plan-title">近期计划</h3>
								<ol class="plan-list">
									{currentPlans.map((plan) => <li>{plan}</li>)}
								</ol>
							</section>
						</div>
						<ul class="post-list">
							{
								recentPosts.map((post) => (
									<li class="post-item">
										<p class="post-meta">
											{post.data.category} / <FormattedDate date={post.data.pubDate} />
										</p>
										<h3><a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a></h3>
										<p>{post.data.description}</p>
									</li>
								))
							}
						</ul>
					</article>

					<article class="space-panel soft-reveal" id="panel-posts" role="tabpanel" data-panel="posts" hidden>
						<div class="panel-heading">
							<div>
								<h2>发布内容</h2>
								<p>文章按时间排序，主要是开发日志、踩坑记录、学习笔记和工具配置。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/blog/')}>进入文章页</a>
						</div>
						<div class="post-tools" aria-label="文章筛选工具">
							<label class="filter-field">
								<span class="tool-label">文章搜索</span>
								<input class="focus-ring" data-post-search type="search" placeholder="搜索标题、描述、标签" />
							</label>
							<label class="filter-field">
								<span class="tool-label">分类筛选</span>
								<select class="focus-ring" data-category-filter>
									<option value="">全部分类</option>
									{categories.map((category) => <option value={category}>{category}</option>)}
								</select>
							</label>
							<p class="filter-count" data-filter-count>显示 {posts.length} / {posts.length} 篇</p>
						</div>
						{
							posts.length > 0 ? (
								<ul class="post-list">
									{
										posts.map((post) => (
											<li
												class="post-item"
												data-post-item
												data-category={post.data.category}
												data-search={`${post.data.title} ${post.data.description} ${post.data.category} ${post.data.tags.join(' ')}`}
											>
												<p class="post-meta">
													{post.data.category} / <FormattedDate date={post.data.pubDate} />
												</p>
												<h3><a href={withBase(`/blog/${post.id}/`)}>{post.data.title}</a></h3>
												<p>{post.data.description}</p>
											</li>
										))
									}
								</ul>
							) : (
								<p class="empty-state">还没有发布文章。</p>
							)
						}
						<p class="empty-state" data-filter-empty hidden>没有匹配文章，试试换个关键词或分类。</p>
					</article>

					<article class="space-panel soft-reveal" id="panel-categories" role="tabpanel" data-panel="categories" hidden>
						<div class="panel-heading">
							<div>
								<h2>知识模块</h2>
								<p>分类对应学习和发布方向，帮助我回看每个阶段主要练了什么。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/categories/')}>查看分类页</a>
						</div>
						<ul class="category-grid">
							{
								categoryCounts.map(({ category, count }) => (
									<li>
										<button class="category-pill focus-ring" type="button" data-category-shortcut={category}>
											<strong>{category}</strong>
											<span>{count} 篇</span>
										</button>
									</li>
								))
							}
						</ul>
						<p class="empty-state">点击分类可以跳到文章面板，并自动完成分类筛选。</p>
						{
							allTags.length > 0 && (
								<>
									<h3>常用标签</h3>
									<ul class="tag-list">
										{allTags.map((tag) => <li class="tag-pill">{tag}</li>)}
									</ul>
								</>
							)
						}
					</article>

					<article class="space-panel soft-reveal" id="panel-about" role="tabpanel" data-panel="about" hidden>
						<div class="panel-heading">
							<div>
								<h2>关于这个空间</h2>
								<p>这是一个入门开发者的公开学习仓库，用博客形式保存过程。</p>
							</div>
							<a class="panel-link focus-ring" href={withBase('/about/')}>完整介绍</a>
						</div>
						<div class="about-body">
							<p>
								我会把每次学习、调试、部署和优化写成能复盘的记录。内容不追求“很高级”，
								但要尽量真实：问题是什么、怎么定位、最后怎么解决、下次如何少走弯路。
							</p>
							<section aria-labelledby="project-title">
								<h3 id="project-title">项目卡片</h3>
								<div class="project-grid">
									{
										projectCards.map((project) => (
											<article class="project-card" data-project-card>
												<div class="project-head">
													<h4>{project.name}</h4>
													<span class="project-status">{project.status}</span>
												</div>
												<p>{project.description}</p>
											</article>
										))
									}
								</div>
							</section>
							<section class="tech-stack" aria-labelledby="stack-title">
								<h3 id="stack-title">技术栈</h3>
								<ul class="tag-list">
									{techStack.map((tech) => <li class="tag-pill">{tech}</li>)}
								</ul>
							</section>
							<section class="interaction-card" aria-labelledby="interaction-title" data-local-interactions>
								<h3 id="interaction-title">访客互动台</h3>
								<p class="interaction-note">
									这里先做静态博客可用的本地互动：访客昵称、本地点赞、本地收藏和留言草稿都会保存在当前浏览器。
								</p>
								<div class="interaction-grid">
									<label class="interaction-field">
										<span class="tool-label">访客昵称</span>
										<input
											class="focus-ring"
											data-visitor-name
											type="text"
											maxlength="20"
											placeholder="例如：学习中的访客"
										/>
									</label>
									<div class="interaction-field">
										<span class="tool-label">本地状态</span>
										<div class="interaction-actions">
											<button class="interaction-button focus-ring" type="button" data-like-button>
												本地点赞 <span data-like-count>0</span>
											</button>
											<button class="interaction-button focus-ring" type="button" data-favorite-button>
												本地收藏
											</button>
										</div>
									</div>
									<label class="interaction-field full">
										<span class="tool-label">留言草稿</span>
										<textarea
											class="focus-ring"
											data-comment-draft
											maxlength="240"
											placeholder="写下想对这个博客说的话；当前版本只保存在你的浏览器里。"
										></textarea>
									</label>
									<div class="interaction-field full">
										<span class="tool-label">草稿预览 <strong class="local-badge">LOCAL ONLY</strong></span>
										<p class="comment-preview" data-comment-preview>还没有留言草稿。</p>
									</div>
								</div>
							</section>
							<div class="about-actions">
								<a class="button focus-ring" href={withBase('/blog/')}>阅读开发日志</a>
								<a class="button secondary focus-ring" href={withBase('/about/')}>了解学习路线</a>
							</div>
						</div>
					</article>
				</div>
			</section>
		</main>
		<Footer />
		<script is:inline>
			const tabs = Array.from(document.querySelectorAll('[data-panel-target]'));
			const panels = Array.from(document.querySelectorAll('[data-panel]'));
			const postSearch = document.querySelector('[data-post-search]');
			const categoryFilter = document.querySelector('[data-category-filter]');
			const filterCount = document.querySelector('[data-filter-count]');
			const filterEmpty = document.querySelector('[data-filter-empty]');
			const postItems = Array.from(document.querySelectorAll('[data-post-item]'));
			const categoryShortcuts = Array.from(document.querySelectorAll('[data-category-shortcut]'));
			const visitorName = document.querySelector('[data-visitor-name]');
			const likeButton = document.querySelector('[data-like-button]');
			const likeCount = document.querySelector('[data-like-count]');
			const favoriteButton = document.querySelector('[data-favorite-button]');
			const commentDraft = document.querySelector('[data-comment-draft]');
			const commentPreview = document.querySelector('[data-comment-preview]');
			const visitorStorageKey = 'hilavera-blog-visitor-state';

			function normalizeText(value) {
				return String(value || '').trim().toLowerCase();
			}

			function readVisitorState() {
				try {
					const savedState = window.localStorage.getItem(visitorStorageKey);
					return savedState
						? JSON.parse(savedState)
						: { name: '', liked: false, favorite: false, likes: 0, comment: '' };
				} catch {
					return { name: '', liked: false, favorite: false, likes: 0, comment: '' };
				}
			}

			function writeVisitorState(state) {
				window.localStorage.setItem(visitorStorageKey, JSON.stringify(state));
			}

			function getVisitorStateFromInputs() {
				return {
					...readVisitorState(),
					name: visitorName?.value.trim() || '',
					comment: commentDraft?.value.trim() || '',
				};
			}

			function updateVisitorState(state = readVisitorState()) {
				if (visitorName) visitorName.value = state.name || '';
				if (commentDraft) commentDraft.value = state.comment || '';
				if (likeCount) likeCount.textContent = String(state.likes || 0);
				if (commentPreview) {
					const visitorLabel = state.name ? `${state.name}：` : '';
					commentPreview.textContent = state.comment ? `${visitorLabel}${state.comment}` : '还没有留言草稿。';
				}
				likeButton?.classList.toggle('is-active', Boolean(state.liked));
				favoriteButton?.classList.toggle('is-active', Boolean(state.favorite));
				likeButton?.setAttribute('aria-pressed', String(Boolean(state.liked)));
				favoriteButton?.setAttribute('aria-pressed', String(Boolean(state.favorite)));
			}

			function saveCommentDraft() {
				const nextState = getVisitorStateFromInputs();
				writeVisitorState(nextState);
				updateVisitorState(nextState);
			}

			function showPanel(panelId) {
				tabs.forEach((tab) => {
					const isActive = tab.dataset.panelTarget === panelId;
					tab.classList.toggle('is-active', isActive);
					tab.setAttribute('aria-selected', String(isActive));
				});

				panels.forEach((panel) => {
					const isActive = panel.dataset.panel === panelId;
					panel.classList.toggle('is-active', isActive);
					panel.toggleAttribute('hidden', !isActive);
					if (isActive) {
						panel.classList.remove('soft-reveal');
						void panel.offsetWidth;
						panel.classList.add('soft-reveal');
					}
				});

				if (window.history.replaceState) {
					window.history.replaceState(null, '', `#${panelId}`);
				}
			}

			function filterPosts() {
				const query = normalizeText(postSearch?.value);
				const selectedCategory = categoryFilter?.value || '';
				let visibleCount = 0;

				postItems.forEach((item) => {
					const matchesQuery = !query || normalizeText(item.dataset.search).includes(query);
					const matchesCategory = !selectedCategory || item.dataset.category === selectedCategory;
					const isVisible = matchesQuery && matchesCategory;

					item.classList.toggle('is-hidden', !isVisible);
					if (isVisible) visibleCount += 1;
				});

				if (filterCount) {
					filterCount.textContent = `显示 ${visibleCount} / ${postItems.length} 篇`;
				}

				if (filterEmpty) {
					filterEmpty.hidden = visibleCount !== 0;
				}
			}

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => showPanel(tab.dataset.panelTarget));
			});

			postSearch?.addEventListener('input', filterPosts);
			categoryFilter?.addEventListener('change', filterPosts);
			visitorName?.addEventListener('input', saveCommentDraft);
			commentDraft?.addEventListener('input', saveCommentDraft);

			likeButton?.addEventListener('click', () => {
				const nextState = getVisitorStateFromInputs();
				nextState.liked = !nextState.liked;
				nextState.likes = nextState.liked ? 1 : 0;
				writeVisitorState(nextState);
				updateVisitorState(nextState);
			});

			favoriteButton?.addEventListener('click', () => {
				const nextState = getVisitorStateFromInputs();
				nextState.favorite = !nextState.favorite;
				writeVisitorState(nextState);
				updateVisitorState(nextState);
			});

			categoryShortcuts.forEach((button) => {
				button.addEventListener('click', () => {
					if (categoryFilter) {
						categoryFilter.value = button.dataset.categoryShortcut || '';
					}
					showPanel('posts');
					filterPosts();
					postSearch?.focus();
				});
			});

			const initialPanel = window.location.hash.replace('#', '');
			if (tabs.some((tab) => tab.dataset.panelTarget === initialPanel)) {
				showPanel(initialPanel);
			}

			filterPosts();
			updateVisitorState();
		</script>
	</body>
</html>
