---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} {SITE_TITLE}。用 Astro 构建。
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: #07111f;
		border-top: 1px solid rgba(125, 211, 252, 16%);
		color: #94a3b8;
		text-align: center;
	}
</style>
