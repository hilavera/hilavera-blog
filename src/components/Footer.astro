---
import { SITE_TITLE } from '../consts';

const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} {SITE_TITLE}。用 Astro 构建。
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background:
			radial-gradient(circle at 50% 0%, rgba(214, 181, 109, 10%), transparent 24rem),
			var(--premium-ink);
		border-top: 1px solid var(--premium-border);
		color: var(--premium-muted);
		text-align: center;
	}
</style>
