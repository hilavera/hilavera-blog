---
import type { HTMLAttributes } from 'astro/types';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;
const pathname = Astro.url.pathname.replace(import.meta.env.BASE_URL, '');
const hrefValue = href?.toString() ?? '/';
const isInternal = hrefValue.startsWith('/');
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const resolvedHref = isInternal ? `${basePath}${hrefValue}` : hrefValue;
const subpath = pathname.match(/[^\/]+/g);
const isActive = hrefValue === pathname || hrefValue === '/' + (subpath?.[0] || '');
---

<a href={resolvedHref} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
